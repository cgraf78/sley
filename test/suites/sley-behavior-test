echo "=== sley: --path symlink-via-non-existent path is rejected ==="

# Non-existent paths used to resolve via `realpath -m`, which canonicalizes
# lexically and skips parent-chain symlinks. A symlinked subdir + missing leaf
# could then escape the repo boundary. Resolve through the existing parent
# with pwd -P so the symlink is followed before judging the boundary.
repo=$(_new_repo)
escape_target=$(_tmpdir)
ln -s "$escape_target" "$repo/escape-link"
_run_sley "$repo" changes --path escape-link/missing-file
_assert_exit "changes: symlinked subdir with missing leaf is treated as outside repo" 2 "$__SLEY_RC"
_assert_contains "changes: symlinked subdir with missing leaf reports outside-repo" "outside repo" "$__SLEY_OUT"

echo "=== sley: sourced API survives a usage error in every public wrapper ==="

# Per the spec, sley.sh is a library that can be sourced by humans, agents,
# tests, and editor integrations. A `--path /outside` should `return 2` from
# every public wrapper, NOT `exit 2` (which would terminate the caller's
# interactive shell). This regression coverage checks every wrapper that
# routes through `_sley_selected_files` plus the path-validating ones.
repo=$(_new_repo)
home=$(_tmpdir)
_copy_sley_libs "$home"
mockbin=$(_mock_bin)
for tool in autoformat autolint gitleaks; do
  cat >"$mockbin/$tool" <<MOCK
#!/usr/bin/env bash
exit 0
MOCK
  chmod +x "$mockbin/$tool"
done
echo "x = 1" >"$repo/seed.py"
(cd "$repo" && git add seed.py && git commit -q -m "seed")
echo "x = 2" >"$repo/seed.py"

for cmd in status changes fix check secrets verify ready; do
  out=$(
    cd "$repo" || exit 99
    HOME="$home" PATH="$mockbin:$PATH" GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
      bash -c "
        source \"$home/sley-root/lib/sley/sley.sh\";
        sley_$cmd --path /tmp >/dev/null 2>&1
        echo survived=\$?
      "
  )
  if [[ "$out" == survived=2 ]]; then
    _pass "sourced sley_$cmd --path /outside returns 2 (caller shell survives)"
  else
    _fail "sourced sley_$cmd --path /outside returns 2 (got: $out)"
  fi
done

echo "=== sley: public wrappers preserve caller CWD ==="

# `_sley_init_repo` cds into the repo root so the implementation can run
# git/sl commands. Public wrappers must restore the caller's CWD afterward
# so a sourced consumer's interactive shell does not silently inherit the cd.
repo=$(_new_repo)
home=$(_tmpdir)
_copy_sley_libs "$home"
caller_dir=$(_tmpdir)

for cmd in status changes select; do
  cwd_after=$(
    cd "$caller_dir" || exit 99
    HOME="$home" GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" bash -c "
      source \"$home/sley-root/lib/sley/sley.sh\";
      cd '$repo' || exit 99
      sley_$cmd >/dev/null 2>&1
      pwd
    "
  )
  if [[ "$cwd_after" == "$repo" ]]; then
    _pass "sley_$cmd preserves caller CWD ($repo)"
  else
    _fail "sley_$cmd preserves caller CWD (got: $cwd_after, expected: $repo)"
  fi
done

echo "=== sley: status validates --path against repo boundary ==="

repo=$(_new_repo)
_run_sley "$repo" status --path /tmp
_assert_exit "status: --path outside repo exits 2" 2 "$__SLEY_RC"
_assert_contains "status: --path outside repo reports error" "outside repo" "$__SLEY_OUT"

echo "=== sley: ready validates --path before phase aggregation ==="

# Without orchestrator-level path-scope validation, an outside-repo --path
# would have each phase return 2 (which `ready` downgrades to "unavailable"),
# masking the spec-required exit-2 behavior under a green run.
repo=$(_new_repo)
home=$(_tmpdir)
_copy_sley_libs "$home"
HOME="$home" _run_sley "$repo" ready --path /tmp
_assert_exit "ready: --path outside repo exits 2" 2 "$__SLEY_RC"
_assert_contains "ready: --path outside repo reports error" "outside repo" "$__SLEY_OUT"

echo "=== sley: secrets --commit --include-untracked scans untracked files ==="

# `_repo_changed_names("staged", 1)` adds untracked files to the change set,
# but the staged-blob scan only covers the index. Without an explicit
# untracked worktree pass, those files were silently skipped — a security
# gap for the secrets gate.
repo=$(_new_repo)
mockbin=$(_mock_bin)
export MOCK_LOG="$repo/gitleaks.log"
: >"$MOCK_LOG"
cat >"$mockbin/gitleaks" <<'MOCK'
#!/usr/bin/env bash
printf '%s\n' "$*" >>"$MOCK_LOG"
cat >>"$MOCK_LOG"
exit 0
MOCK
chmod +x "$mockbin/gitleaks"
echo "x = 1" >"$repo/staged.py"
(cd "$repo" && git add staged.py && git commit -q -m "seed")
echo "x = 2" >"$repo/staged.py"
(cd "$repo" && git add staged.py)
# Untracked file added to the worktree but never staged.
echo "secret_token = \"unstaged-secret\"" >"$repo/untracked-secret.py"

PATH="$mockbin:$PATH" _run_sley "$repo" secrets --commit --include-untracked
_assert_exit "secrets --commit --include-untracked: succeeds" 0 "$__SLEY_RC"
_assert_contains "secrets --commit --include-untracked: scans staged blob via stdin" \
  "stdin --redact --no-banner" "$(cat "$MOCK_LOG")"
_assert_contains "secrets --commit --include-untracked: scans untracked file via worktree" \
  "untracked-secret.py" "$(cat "$MOCK_LOG")"

echo "=== sley: dash-prefixed filename does not get parsed as a flag ==="

# Files with leading `-` were the missing-`--` regression slot. Each entry
# point that forwards filenames to autoformat/autolint/gitleaks needs a `--`
# separator so a hostile or unusual filename like `-rf.py` is treated as a
# positional path argument, not as a flag.
repo=$(_new_repo)
mockbin=$(_mock_bin)
export MOCK_LOG="$repo/dash-prefix.log"
: >"$MOCK_LOG"
cat >"$mockbin/autoformat" <<'MOCK'
#!/usr/bin/env bash
printf 'autoformat:%s\n' "$*" >>"$MOCK_LOG"
MOCK
cat >"$mockbin/autolint" <<'MOCK'
#!/usr/bin/env bash
printf 'autolint:%s\n' "$*" >>"$MOCK_LOG"
MOCK
chmod +x "$mockbin/autoformat" "$mockbin/autolint"
# Stage a file whose name begins with `-`. Use `git add --` so the leading
# dash is not interpreted by git itself either.
echo "x = 1" >"$repo/-rf.py"
(cd "$repo" && git add -- -rf.py && git commit -q -m "seed")
echo "x = 2" >"$repo/-rf.py"

PATH="$mockbin:$PATH" _run_sley "$repo" fix
_assert_exit "fix: dash-prefixed filename succeeds" 0 "$__SLEY_RC"
_assert_contains "fix: passes -- before dash-prefixed filename" "-- -rf.py" "$(cat "$MOCK_LOG")"

echo "=== sley: autoformat reading stdin does not drain the herestring loop ==="

# The fix loop reads filenames from a herestring. If autoformat ever reads
# stdin (interactive prompt, tty probe), it would drain the rest and silently
# skip files. Each autoformat invocation must redirect stdin from /dev/null.
repo=$(_new_repo)
mockbin=$(_mock_bin)
export MOCK_LOG="$repo/stdin-drain.log"
: >"$MOCK_LOG"
cat >"$mockbin/autoformat" <<'MOCK'
#!/usr/bin/env bash
# Pretend the formatter slurps stdin. Without `</dev/null` in the caller, this
# would drain the rest of the herestring and orphan the second file. Print
# the trailing positional arg (the filename) — autoformat is invoked as
# `autoformat -- <file>` so the last arg is the file path.
cat >/dev/null
printf 'autoformat:%s\n' "${@: -1}" >>"$MOCK_LOG"
MOCK
chmod +x "$mockbin/autoformat"
echo "x = 1" >"$repo/first.py"
echo "x = 1" >"$repo/second.py"
(cd "$repo" && git add first.py second.py && git commit -q -m "seed")
echo "x = 2" >"$repo/first.py"
echo "x = 2" >"$repo/second.py"

PATH="$mockbin:$PATH" _run_sley "$repo" fix
_assert_contains "fix: stdin-reading formatter still gets first file" "autoformat:first.py" "$(cat "$MOCK_LOG")"
_assert_contains "fix: stdin-reading formatter still gets second file" "autoformat:second.py" "$(cat "$MOCK_LOG")"

echo "=== sley: JSON escape python3 fallback does not trail with newline ==="

# `_repo_json_escape` falls back to python3 when jq is missing. The herestring
# fix here is critical: without it the encoded value silently gains a literal
# `\n` because `<<<` adds a trailing newline that `sys.stdin.read()` then
# encodes. Verify the JSON value matches the input bytes exactly.
if command -v python3 >/dev/null 2>&1; then
  no_jq_path=$(_mock_bin)
  out=$(
    HOME="$HOME" PATH="$no_jq_path:/usr/bin:/bin" bash -c '
      source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
      _repo_json_escape "abc"
    '
  )
  if [[ "$out" == "abc" ]]; then
    _pass "json escape: python3 fallback preserves value bytes"
  else
    _fail "json escape: python3 fallback added trailing characters (got: $(printf '%q' "$out"))"
  fi
fi

echo "=== sley: changed-file enumeration drops filenames with embedded newlines ==="

# Regression test for the silent fail-open where line-delimited
# `git diff --name-only` either C-quoted filenames containing `\n` (when
# `core.quotePath=true`, the git default) or let them split into bogus
# multi-line entries downstream (when quoting was disabled). Either outcome
# made the affected file invisible to format/lint/secret scans while the gate
# reported success. The fix routes changed-name enumeration through a `-z`
# (NUL-delimited) pipeline and warns-and-drops any name with an embedded
# newline, converting the silent fail-open into a loud fail-closed.
#
# This test fails (and the bug returns) if any one of these regresses:
#   - `_repo_git_changed_names staged` stops using `-z`
#   - `_repo_emit_safe_paths` stops checking for embedded newlines
#   - the stderr warning is removed or its wording changes meaningfully

repo=$(_new_repo)
echo "ok" >"$repo/normal.txt"
nl_name=$'evil\nfake-second.txt'
printf 'secret\n' >"$repo/$nl_name"
(cd "$repo" && git add -- 'normal.txt' "$nl_name")

nl_stderr_file=$(_tmpdir)/repo_changed_names_stderr.txt
nl_stdout=$(
  cd "$repo" &&
    bash -c '
      source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
      _REPO_TYPE=git
      _REPO_ROOT=$(pwd)
      _repo_git_changed_names staged 0
    ' 2>"$nl_stderr_file"
)
nl_stderr=$(cat "$nl_stderr_file")

_assert_contains "changed-names: normal sibling still emitted" "normal.txt" "$nl_stdout"
_assert_not_contains "changed-names: newline-bearing name not emitted as a path entry" "evil" "$nl_stdout"
_assert_not_contains "changed-names: split fake-second fragment not emitted as a path entry" "fake-second.txt" "$nl_stdout"
_assert_contains "changed-names: warns on dropped newline-bearing filename" "embedded newline" "$nl_stderr"

echo "=== sley: verify cache lock reclaims stale lock owned by dead PID ==="

# Regression test for the stale-lock hang where `_sley_verify_cache_lock_acquire`
# used `mkdir` as the lock primitive without any owner metadata. A SIGKILL
# (or power loss) between mkdir and the explicit `rmdir` release would leave
# the lock dir on disk forever; every subsequent run for the same cache key
# spent the full 5s mkdir-polling budget before falling through unlocked,
# AND a duplicate same-key execution could happen because the post-poll
# branch ran uncached without holding the lock. The fix records PID + host
# in `owner.meta` and reclaims locks whose recorded PID is no longer alive
# on this host.
#
# This test fails (and the bug returns) if any one of these regresses:
#   - `_sley_verify_cache_lock_acquire` stops writing owner.meta
#   - `_sley_verify_cache_lock_is_stale` stops checking PID liveness with `kill -0`
#   - The reclaim path in the acquire loop is removed

verify_lock_root=$(_tmpdir)/locks
mkdir -p "$verify_lock_root"
# Build a receipt path that matches what the function expects:
#   dirname(dirname(receipt))/locks/basename(receipt).lock
verify_receipt_parent=$(_tmpdir)/cache/receipts
mkdir -p "$verify_receipt_parent"
verify_receipt="$verify_receipt_parent/test-key.json"
verify_expected_lock_root="$(dirname "$(dirname "$verify_receipt")")/locks"
verify_expected_lock_dir="$verify_expected_lock_root/$(basename "$verify_receipt").lock"

# Seed a stale lock that claims to be owned by PID 999999999 (effectively
# guaranteed to not exist on a Linux system; max PID is typically <2^22).
mkdir -p "$verify_expected_lock_dir"
{
  printf 'pid=999999999\n'
  printf 'host=%s\n' "${HOSTNAME:-$(uname -n)}"
  printf 'started=%s\n' "$(date +%s)"
} >"$verify_expected_lock_dir/owner.meta"

# Force the lock mtime well into the past so any future age-based heuristic
# would also classify it as stale. (Current fix uses PID liveness, not age,
# but the seed should remain stale under either policy.)
touch -d '2 hours ago' "$verify_expected_lock_dir" 2>/dev/null || true

lock_stderr_file=$(_tmpdir)/verify_lock_stderr.txt
lock_stdout=$(
  bash -c '
    source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
    source "$SLEY_REPO_ROOT/lib/sley/scope.sh"
    source "$SLEY_REPO_ROOT/lib/sley/hooks.sh"
    source "$SLEY_REPO_ROOT/lib/sley/verify.sh"
    _sley_verify_cache_lock_acquire "'"$verify_receipt"'"
  ' 2>"$lock_stderr_file"
)
# Capture the bash -c subprocess's rc IMMEDIATELY after the command
# substitution. The earlier version of this test deferred to `cat`'s rc
# via `lock_stderr=$(cat ...); lock_rc=$?`, which is always 0 — the
# success-rc assertion below would pass vacuously even if reclaim
# silently broke. Read the stderr file AFTER capturing rc.
lock_rc=$?
lock_stderr=$(cat "$lock_stderr_file")

_assert_eq "verify lock: acquire reclaims stale lock and returns the lock dir path" "$verify_expected_lock_dir" "$lock_stdout"
_assert_eq "verify lock: acquire returns success rc after reclaim" "0" "$lock_rc"
_assert_contains "verify lock: emits stderr notice when reclaiming a stale lock" "reclaiming stale cache lock" "$lock_stderr"

# Confirm the new acquisition wrote fresh owner metadata that is NOT the
# bogus 999999999 PID from our seed — proves we reclaimed and re-acquired
# rather than just reusing the seed. We cannot assert against `$$` of the
# outer test shell because the bash subshell that ran the acquire has its
# own PID; the meaningful invariant is "PID is numeric, not the seed".
verify_owner_meta="$verify_expected_lock_dir/owner.meta"
if [[ -f "$verify_owner_meta" ]]; then
  reclaimed_pid=$(awk -F= '$1=="pid" {print $2; exit}' "$verify_owner_meta")
  if [[ "$reclaimed_pid" =~ ^[0-9]+$ ]] && [[ "$reclaimed_pid" != "999999999" ]]; then
    _pass "verify lock: reclaimed acquisition stamps fresh owner PID"
  else
    _fail "verify lock: reclaim left stale PID metadata (got '$reclaimed_pid')"
  fi
else
  _fail "verify lock: owner.meta missing after reclaim"
fi

# Clean up our seeded lock so other tests aren't polluted.
rm -rf "$verify_expected_lock_dir" 2>/dev/null || true

echo "=== sley: verify cache lock leaves live-PID locks alone ==="

# Counterpart to the reclaim test: a stale-looking lock owned by an ALIVE
# PID (our own shell) must NOT be reclaimed. This pins the conservative
# branch of `_sley_verify_cache_lock_is_stale`.

mkdir -p "$verify_expected_lock_dir"
{
  printf 'pid=%s\n' "$$"
  printf 'host=%s\n' "${HOSTNAME:-$(uname -n)}"
  printf 'started=%s\n' "$(date +%s)"
} >"$verify_expected_lock_dir/owner.meta"

lock_live_stderr_file=$(_tmpdir)/verify_lock_live_stderr.txt
lock_live_stdout=$(
  bash -c '
    source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
    source "$SLEY_REPO_ROOT/lib/sley/scope.sh"
    source "$SLEY_REPO_ROOT/lib/sley/hooks.sh"
    source "$SLEY_REPO_ROOT/lib/sley/verify.sh"
    _sley_verify_cache_lock_acquire "'"$verify_receipt"'"
  ' 2>"$lock_live_stderr_file"
)
lock_live_rc=$?
lock_live_stderr=$(cat "$lock_live_stderr_file")

_assert_eq "verify lock: alive-PID lock not reclaimed (rc=1 after polling timeout)" "1" "$lock_live_rc"
_assert_eq "verify lock: alive-PID lock holds — no path printed" "" "$lock_live_stdout"
_assert_not_contains "verify lock: alive-PID lock does not emit reclaim notice" "reclaiming stale" "$lock_live_stderr"

# Verify the seed PID is still recorded (proves we did not silently
# reclaim+rewrite owner.meta).
if [[ -f "$verify_owner_meta" ]]; then
  preserved_pid=$(awk -F= '$1=="pid" {print $2; exit}' "$verify_owner_meta")
  _assert_eq "verify lock: alive-PID lock preserves original owner.meta" "$$" "$preserved_pid"
else
  _fail "verify lock: alive-PID lock owner.meta unexpectedly removed"
fi

rm -rf "$verify_expected_lock_dir" 2>/dev/null || true

echo "=== sley: secrets worktree scan preserves max-severity rc across files/batches ==="

# Regression test for the silent-downgrade bug in
# `_sley_secrets_scan_worktree_files` (and the per-batch loop in
# `_sley_secrets_scan_batch`). gitleaks's exit-code protocol overloads
# severity onto the numeric value: rc=0 clean, rc=1 leaks found, rc≥2
# scanner/IO error. The pre-fix code did `rc=$scan_rc` unconditionally on
# every non-zero, so a later "leaks found" (rc=1) silently downgraded an
# earlier "scanner failed" (rc≥2) and shipped a "leaks reported, treated as
# scanner-clean" verdict that hid the broken scan. The fix preserves the
# MAX rc across files and batches.
#
# Both the single-job code path and the parallel batched path are
# exercised so a regression in either branch fails this test.

secrets_rc_repo=$(_tmpdir)
echo "alpha" >"$secrets_rc_repo/alpha.txt"
echo "beta" >"$secrets_rc_repo/beta.txt"

secrets_rc_mockbin=$(_mock_bin)
# Mock gitleaks: rc=2 for paths containing 'alpha' (scanner error), rc=1
# for paths containing 'beta' (leaks-found). Both files are non-zero so
# every call returns a failure; only the MAX-preserve discipline produces
# the right final rc.
cat >"$secrets_rc_mockbin/gitleaks" <<'MOCK'
#!/usr/bin/env bash
last="${!#}"
case "$last" in
  *alpha*) exit 2 ;;
  *beta*) exit 1 ;;
  *) exit 0 ;;
esac
MOCK
chmod +x "$secrets_rc_mockbin/gitleaks"

# Single-job path: SLEY_SECRETS_JOBS=1 forces the for-each-file branch.
single_rc=$(
  PATH="$secrets_rc_mockbin:$PATH" SLEY_SECRETS_JOBS=1 \
    bash -c '
      source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
      source "$SLEY_REPO_ROOT/lib/sley/scope.sh"
      source "$SLEY_REPO_ROOT/lib/sley/hooks.sh"
      source "$SLEY_REPO_ROOT/lib/sley/verify.sh"
      source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
      _REPO_TYPE=git
      _REPO_ROOT='"$secrets_rc_repo"'
      _sley_secrets_scan_worktree_files '"$secrets_rc_repo/alpha.txt $secrets_rc_repo/beta.txt"' >/dev/null 2>&1
      printf "%s\n" "$?"
    '
)
_assert_eq "secrets worktree (1 job): final rc preserves max (alpha=2, beta=1 → rc=2)" "2" "$single_rc"

# Reverse the file order to confirm the result is order-independent. Without
# the fix, this case returned 2 because beta(1) ran first then alpha(2)
# overwrote — the bug only manifested when the higher-rc file came first.
single_rc_reverse=$(
  PATH="$secrets_rc_mockbin:$PATH" SLEY_SECRETS_JOBS=1 \
    bash -c '
      source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
      source "$SLEY_REPO_ROOT/lib/sley/scope.sh"
      source "$SLEY_REPO_ROOT/lib/sley/hooks.sh"
      source "$SLEY_REPO_ROOT/lib/sley/verify.sh"
      source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
      _REPO_TYPE=git
      _REPO_ROOT='"$secrets_rc_repo"'
      _sley_secrets_scan_worktree_files '"$secrets_rc_repo/beta.txt $secrets_rc_repo/alpha.txt"' >/dev/null 2>&1
      printf "%s\n" "$?"
    '
)
_assert_eq "secrets worktree (1 job, reversed order): final rc still preserves max" "2" "$single_rc_reverse"

# Parallel batched path: SLEY_SECRETS_JOBS=4 routes through
# `_sley_secrets_scan_batch`, which has its own max-preserve fix.
parallel_rc=$(
  PATH="$secrets_rc_mockbin:$PATH" SLEY_SECRETS_JOBS=4 \
    bash -c '
      source "$SLEY_REPO_ROOT/lib/sley/repo.sh"
      source "$SLEY_REPO_ROOT/lib/sley/scope.sh"
      source "$SLEY_REPO_ROOT/lib/sley/hooks.sh"
      source "$SLEY_REPO_ROOT/lib/sley/verify.sh"
      source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
      _REPO_TYPE=git
      _REPO_ROOT='"$secrets_rc_repo"'
      _sley_secrets_scan_worktree_files '"$secrets_rc_repo/beta.txt $secrets_rc_repo/alpha.txt"' >/dev/null 2>&1
      printf "%s\n" "$?"
    '
)
_assert_eq "secrets worktree (parallel batch): final rc preserves max across batch members" "2" "$parallel_rc"

echo "=== sley: secrets outer aggregator preserves max-severity rc across staged-blob and worktree passes ==="

# Regression test for the OUTER `_sley_secrets` aggregator's MAX-rc fix.
# The earlier commit (e1ab7ca) only fixed the inner functions
# (`_sley_secrets_scan_batch`, `_sley_secrets_scan_worktree_files`). The
# outer aggregator at sley.sh:~764 / ~801 still did `rc=$scan_rc` and
# `|| rc=$?` — last-non-zero-wins — so a higher-severity staged-blob
# scanner error (rc=2) was silently downgraded by a later "leaks found"
# (rc=1) from the worktree scan, exactly the bug class the inner fix
# was meant to eliminate.
#
# Cross-model adversarial review (Codex) caught this gap during the
# re-review pass. The fix MAX-preserves at both aggregator sites.

outer_repo=$(_new_repo)
outer_mockbin=$(_mock_bin)
export OUTER_MOCK_LOG="$outer_repo/gitleaks-outer.log"
: >"$OUTER_MOCK_LOG"
# Mock gitleaks: rc=2 when called as `gitleaks stdin ...` (the staged-blob
# scan path uses `git diff --cached | gitleaks stdin`), rc=1 when called
# as `gitleaks dir -- <file>` (the worktree scan path). The outer
# aggregator should preserve the MAX (2), not the last (1).
cat >"$outer_mockbin/gitleaks" <<'MOCK'
#!/usr/bin/env bash
printf '%s\n' "$*" >>"$OUTER_MOCK_LOG"
case "$1" in
  stdin) exit 2 ;;
  dir) exit 1 ;;
  *) exit 0 ;;
esac
MOCK
chmod +x "$outer_mockbin/gitleaks"

# Set up a file that is BOTH staged AND modified in the worktree, so
# `_sley_secrets` runs both the staged-blob pass (via `git diff --cached
# | gitleaks stdin`) and the worktree pass (via
# `_sley_secrets_scan_worktree_files`). The worktree-path branch at
# sley.sh:~770-783 skips files where the worktree matches staged, so we
# must make them differ.
echo "x = 1" >"$outer_repo/dual.py"
(cd "$outer_repo" && git add dual.py && git commit -q -m "seed")
echo "x = 2" >"$outer_repo/dual.py"
(cd "$outer_repo" && git add dual.py)
echo "x = 3" >"$outer_repo/dual.py"

PATH="$outer_mockbin:$PATH" _run_sley "$outer_repo" secrets
outer_rc=$__SLEY_RC

# Confirm both passes ran (so we know the test actually exercises both
# code paths, not just one).
