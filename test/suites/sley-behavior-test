#!/usr/bin/env bash
# sley-test — unit tests for the sley repo workflow CLI.
#
# Each test uses isolated temp repos and mock tools. The suite exercises
# user-visible CLI contracts before implementation details.

# shellcheck disable=SC1091,SC2030,SC2031 # dynamic sources and subshell git fixtures.
set -o pipefail
export NO_COLOR=1

SLEY_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
SLEY_REPO_ROOT="$(cd -- "$SLEY_TEST_DIR/.." && pwd -P)"
export SLEY_REPO_ROOT

# shellcheck source=../helpers.sh
. "$SLEY_TEST_DIR/helpers.sh"

_require_compatible_libc "sley-test"

SLEY="$SLEY_REPO_ROOT/bin/sley"
SLEY_TEST_HOME="$HOME"
SLEY_TEST_XDG_CONFIG_HOME=$(_tmpdir)/xdg-config
SLEY_TEST_XDG_CACHE_HOME=$(_tmpdir)/xdg-cache

echo "=== sley: public shell API ==="

shell_completion_output=$(
  # shellcheck disable=SC2016 # Inner bash expands the sourced shell API with SLEY_VERIFY_SCHEMA isolated.
  env -u SLEY_VERIFY_SCHEMA SLEY_REPO_ROOT="$SLEY_REPO_ROOT" bash --noprofile --norc -c '
    source "$SLEY_REPO_ROOT/share/sley/shell.sh"
    COMP_WORDS=(sley "")
    COMP_CWORD=1
    _sley_shell_complete
    printf "cmd:%s\n" "${COMPREPLY[@]}"
    COMP_WORDS=(sley verify "")
    COMP_CWORD=2
    _sley_shell_complete
    printf "opt:%s\n" "${COMPREPLY[@]}"
    printf "schema:%s\n" "${SLEY_VERIFY_SCHEMA:-}"
    printf "schema_fn:%s\n" "$(sley_verify_schema_path)"
  '
)
_assert_contains "shell api: command completion includes verify" \
  "cmd:verify" "$shell_completion_output"
_assert_not_contains "shell api: command completion omits removed workflow" \
  "cmd:workflow" "$shell_completion_output"
_assert_contains "shell api: verify completion includes --commit" \
  "opt:--commit" "$shell_completion_output"
_assert_contains "shell api: verify completion includes --include-untracked" \
  "opt:--include-untracked" "$shell_completion_output"
_assert_contains "shell api: verify completion includes --repo-wide" \
  "opt:--repo-wide" "$shell_completion_output"
_assert_contains "shell api: verify completion includes --path" \
  "opt:--path" "$shell_completion_output"
_assert_contains "shell api: verify completion includes --json" \
  "opt:--json" "$shell_completion_output"
_assert_contains "shell api: exposes verify schema env var" \
  "schema:$SLEY_REPO_ROOT/share/sley/schemas/verify.schema.json" \
  "$shell_completion_output"
_assert_contains "shell api: exposes verify schema helper" \
  "schema_fn:$SLEY_REPO_ROOT/share/sley/schemas/verify.schema.json" \
  "$shell_completion_output"

cached_loader=$(_tmpdir)/sley.bash
cp "$SLEY_REPO_ROOT/share/sley/shell.sh" "$cached_loader"
cached_bin=$(_mock_bin)
cat >"$cached_bin/shdeps" <<EOF
#!/usr/bin/env bash
if [[ "\$1" == "dep-file" &&
  "\$2" == "cgraf78/sley" &&
  "\$3" == "share/sley/schemas/verify.schema.json" ]]; then
  printf '%s\n' "$SLEY_REPO_ROOT/share/sley/schemas/verify.schema.json"
  exit 0
fi
exit 1
EOF
chmod +x "$cached_bin/shdeps"
cached_schema_output=$(
  # shellcheck disable=SC2016 # Inner bash must see the copied loader path and mock shdeps environment.
  env -u SLEY_VERIFY_SCHEMA PATH="$cached_bin:$PATH" bash --noprofile --norc -c '
    source "$1"
    printf "%s\n" "${SLEY_VERIFY_SCHEMA:-}"
  ' bash "$cached_loader"
)
_assert_eq "shell api: cached loader resolves schema through shdeps" \
  "$SLEY_REPO_ROOT/share/sley/schemas/verify.schema.json" \
  "$cached_schema_output"

if command -v zsh >/dev/null 2>&1; then
  zsh_completion_output=$(
    SLEY_REPO_ROOT="$SLEY_REPO_ROOT" zsh -fc '
      autoload -Uz compinit
      compinit -D -i
      source "$SLEY_REPO_ROOT/share/sley/shell.sh"
      compadd() {
        while [[ "$1" == "--" ]]; do
          shift
        done
        printf "match:%s\n" "$@"
      }
      words=(sley "")
      CURRENT=2
      _sley_zsh_complete
      words=(sley verify "")
      CURRENT=3
      _sley_zsh_complete
      print -r -- "registered=${+functions[_sley_zsh_complete]}"
    '
  )
  _assert_contains "shell api: zsh completion function registers" \
    "registered=1" "$zsh_completion_output"
  _assert_contains "shell api: zsh command completion includes verify" \
    "match:verify" "$zsh_completion_output"
  _assert_contains "shell api: zsh verify completion includes --commit" \
    "match:--commit" "$zsh_completion_output"
  _assert_contains "shell api: zsh verify completion includes --include-untracked" \
    "match:--include-untracked" "$zsh_completion_output"
  _assert_contains "shell api: zsh verify completion includes --repo-wide" \
    "match:--repo-wide" "$zsh_completion_output"
  _assert_contains "shell api: zsh verify completion includes --path" \
    "match:--path" "$zsh_completion_output"
  _assert_contains "shell api: zsh verify completion includes --json" \
    "match:--json" "$zsh_completion_output"
  zsh_deferred_output=$(
    SLEY_REPO_ROOT="$SLEY_REPO_ROOT" zsh -fc '
      source "$SLEY_REPO_ROOT/share/sley/shell.sh"
      autoload -Uz compinit
      compinit -D -i
      for hook in "${precmd_functions[@]}"; do "$hook"; done
      print -r -- "registered=${_comps[sley]:-}"
    '
  )
  _assert_contains "shell api: zsh registration defers until compinit" \
    "registered=_sley_zsh_complete" "$zsh_deferred_output"
else
  echo "  SKIP: shell api zsh completion (zsh not installed)"
fi

_sley_test_xdg_config_home() {
  # sley intentionally honors XDG_CONFIG_HOME, but this suite should not inherit
  # a runner's user verify registry. Default calls get an empty suite-owned config
  # root; tests that override HOME get that mock home's .config so they can
  # exercise user-config discovery hermetically.
  if [[ "$HOME" == "$SLEY_TEST_HOME" ]]; then
    printf '%s\n' "$SLEY_TEST_XDG_CONFIG_HOME"
  else
    printf '%s/.config\n' "$HOME"
  fi
}

_new_repo() {
  local repo
  repo=$(_tmpdir)
  (
    cd "$repo" || exit 1
    export GIT_CONFIG_GLOBAL="$repo/.gitconfig-test"
    : >"$GIT_CONFIG_GLOBAL"
    git init -q
    git config user.email test@test.local
    git config user.name "Test User"
    mkdir -p "$repo/.hooks"
    git config core.hooksPath "$repo/.hooks"
    git config commit.gpgsign false
  )
  (cd "$repo" && pwd -P)
}

_no_sley_tools_path() {
  local bin
  bin=$(_mock_bin)
  ln -s "$(command -v bash)" "$bin/bash"
  printf '%s:/usr/bin:/bin' "$bin"
}

_run_sley() {
  local repo="$1"
  shift
  local xdg_config_home
  xdg_config_home=$(_sley_test_xdg_config_home)
  __SLEY_OUT=$(
    cd "$repo" &&
      XDG_CONFIG_HOME="$xdg_config_home" \
        XDG_CACHE_HOME="$SLEY_TEST_XDG_CACHE_HOME" \
        GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" "$SLEY" "$@" 2>&1
  )
  __SLEY_RC=$?
}

_run_sley_from() {
  local repo="$1" dir="$2"
  shift 2
  local xdg_config_home
  xdg_config_home=$(_sley_test_xdg_config_home)
  __SLEY_OUT=$(
    cd "$dir" &&
      XDG_CONFIG_HOME="$xdg_config_home" \
        XDG_CACHE_HOME="$SLEY_TEST_XDG_CACHE_HOME" \
        GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" "$SLEY" "$@" 2>&1
  )
  __SLEY_RC=$?
}

_copy_sley_libs() {
  local home="$1"
  local root="$SLEY_REPO_ROOT"
  local install="$home/sley-root"
  mkdir -p "$install/bin" "$install/lib/sley"
  cp "$root/lib/sley/sley.sh" "$install/lib/sley/sley.sh"
  cp "$root/lib/sley/repo.sh" "$install/lib/sley/repo.sh"
  cp "$root/lib/sley/scope.sh" "$install/lib/sley/scope.sh"
  cp "$root/lib/sley/hooks.sh" "$install/lib/sley/hooks.sh"
  cp "$root/lib/sley/verify.sh" "$install/lib/sley/verify.sh"
  cp "$root/lib/sley/verify-cache.py" "$install/lib/sley/verify-cache.py"
  cp "$root/lib/sley/ready.sh" "$install/lib/sley/ready.sh"
  cp "$root/bin/sley" "$install/bin/sley"
}

_mock_ready_pass_tools() {
  local bin="$1"
  cat >"$bin/autolint" <<'MOCK'
#!/usr/bin/env bash
exit 0
MOCK
  cat >"$bin/gitleaks" <<'MOCK'
#!/usr/bin/env bash
exit 0
MOCK
  cat >"$bin/checkrun" <<'MOCK'
#!/usr/bin/env bash
exit 0
MOCK
  chmod +x "$bin/autolint" "$bin/gitleaks" "$bin/checkrun"
}

_mock_checkrun_verify() {
  local bin="$1"
  mkdir -p "$bin"
  cat >"$bin/checkrun" <<'MOCK'
#!/usr/bin/env bash
exit 0
MOCK
  chmod +x "$bin/checkrun"
}

echo "=== sley: shdeps-installed symlink entry point ==="

symlink_bin=$(_tmpdir)/bin
mkdir -p "$symlink_bin"
ln -s "$SLEY" "$symlink_bin/sley"

set +e
symlink_help=$("$symlink_bin/sley" --help 2>&1)
symlink_rc=$?
_assert_exit "symlink entry: resolves dependency library" 0 "$symlink_rc"
_assert_contains "symlink entry: help still comes from sley" "Usage: sley" "$symlink_help"

echo
echo "=== sley: explicit bare repo fallback ==="

home=$(_tmpdir)
home=$(cd -- "$home" && pwd -P)
mkdir -p "$home/sub" "$home/other"
git --git-dir="$home/.bare-git" --work-tree="$home" init -q
git --git-dir="$home/.bare-git" --work-tree="$home" config user.email test@test.local
git --git-dir="$home/.bare-git" --work-tree="$home" config user.name "Test User"
printf 'one\n' >"$home/sub/in-scope.txt"
printf 'one\n' >"$home/other/out-of-scope.txt"
git --git-dir="$home/.bare-git" --work-tree="$home" add sub/in-scope.txt other/out-of-scope.txt
git --git-dir="$home/.bare-git" --work-tree="$home" commit -q -m "seed"
printf 'untracked\n' >"$home/untracked.txt"

set +e
default_bare_home_out=$(
  cd "$home" || exit 1
  unset SLEY_BARE_REPO_GIT_DIR SLEY_BARE_REPO_WORK_TREE SLEY_SKIP_BARE_REPO_FALLBACK
  HOME="$home" "$symlink_bin/sley" status 2>&1
)
default_bare_home_rc=$?
_assert_exit "bare repo fallback: default leaves non-repo unsupported" 2 "$default_bare_home_rc"
_assert_contains "bare repo fallback: default reports unsupported repo" "unsupported repo" "$default_bare_home_out"

bare_home_status=$(
  cd "$home" || exit 1
  unset SLEY_SKIP_BARE_REPO_FALLBACK
  HOME="$home" \
    SLEY_BARE_REPO_GIT_DIR="$home/.bare-git" \
    SLEY_BARE_REPO_WORK_TREE="$home" \
    "$symlink_bin/sley" status
)
_assert_contains "bare repo fallback: explicit git dir detects repo" "root: $home" "$bare_home_status"
_assert_contains "bare repo fallback: skips untracked HOME scan" "dirty: false" "$bare_home_status"

printf 'two\n' >"$home/sub/in-scope.txt"
printf 'two\n' >"$home/other/out-of-scope.txt"

bare_home_changes=$(
  cd "$home/sub" || exit 1
  unset SLEY_SKIP_BARE_REPO_FALLBACK
  HOME="$home" \
    SLEY_BARE_REPO_GIT_DIR="$home/.bare-git" \
    SLEY_BARE_REPO_WORK_TREE="$home" \
    "$symlink_bin/sley" changes
)
_assert_contains "bare repo fallback: auto-scopes to current subtree" "sub/in-scope.txt" "$bare_home_changes"
_assert_not_contains "bare repo fallback: excludes sibling changes" "other/out-of-scope.txt" "$bare_home_changes"

set +e
skip_out=$(
  cd "$home" || exit 1
  HOME="$home" \
    SLEY_BARE_REPO_GIT_DIR="$home/.bare-git" \
    SLEY_SKIP_BARE_REPO_FALLBACK=1 \
    "$symlink_bin/sley" status 2>&1
)
skip_rc=$?
_assert_exit "bare repo fallback: skip leaves non-repo unsupported" 2 "$skip_rc"
_assert_contains "bare repo fallback: skip reports unsupported repo" "unsupported repo" "$skip_out"

echo "=== sley: git status and changes ==="

dirty_decisions=$(
  SLEY_REPO_ROOT="$SLEY_REPO_ROOT" bash --noprofile --norc -c '
    source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
    printf "clean=%s\n" "$(_sley_dirty_from_counts 0 0 0 0)"
    printf "staged=%s\n" "$(_sley_dirty_from_counts 1 0 0 0)"
    printf "pending=%s\n" "$(_sley_dirty_from_counts 0 1 0 0)"
    printf "unstaged=%s\n" "$(_sley_dirty_from_counts 0 0 1 0)"
    printf "untracked=%s\n" "$(_sley_dirty_from_counts 0 0 0 1)"
  '
)
_assert_contains "status dirty helper: clean counts are clean" "clean=false" "$dirty_decisions"
_assert_contains "status dirty helper: staged count is dirty" "staged=true" "$dirty_decisions"
_assert_contains "status dirty helper: pending count is dirty" "pending=true" "$dirty_decisions"
_assert_contains "status dirty helper: unstaged count is dirty" "unstaged=true" "$dirty_decisions"
_assert_contains "status dirty helper: untracked count is dirty" "untracked=true" "$dirty_decisions"

repo=$(_new_repo)
cat >"$repo/tracked.py" <<'EOF'
x = 1
EOF
(cd "$repo" && git add tracked.py && git commit -q -m "seed")
echo "x = 2" >"$repo/tracked.py"
cat >"$repo/untracked.py" <<'EOF'
y = 1
EOF

_run_sley "$repo" changes
_assert_exit "changes: default changed scope succeeds" 0 "$__SLEY_RC"
_assert_contains "changes: default includes tracked change" "tracked.py" "$__SLEY_OUT"
_assert_not_contains "changes: default excludes untracked" "untracked.py" "$__SLEY_OUT"

_run_sley "$repo" changes --include-untracked
_assert_exit "changes: include-untracked succeeds" 0 "$__SLEY_RC"
_assert_contains "changes: include-untracked includes tracked" "tracked.py" "$__SLEY_OUT"
_assert_contains "changes: include-untracked includes untracked" "untracked.py" "$__SLEY_OUT"

_run_sley "$repo" changes --json
_assert_exit "changes: json succeeds" 0 "$__SLEY_RC"
_assert_contains "changes: json has repo_type" '"repo_type":"git"' "$__SLEY_OUT"
_assert_contains "changes: json has files" '"files":[' "$__SLEY_OUT"
_assert_contains "changes: json includes exists field" '"exists":true' "$__SLEY_OUT"

no_json_encoder_path=$(_mock_bin)
for cmd in bash git dirname; do
  ln -s "$(command -v "$cmd")" "$no_json_encoder_path/$cmd"
done
__SLEY_OUT=$(
  cd "$repo" &&
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$no_json_encoder_path" "$SLEY" status --json 2>&1
)
__SLEY_RC=$?
_assert_exit "status --json: missing encoder exits 2" 2 "$__SLEY_RC"
_assert_contains "status --json: missing encoder reports error" \
  "jq or python3 is required for JSON output" "$__SLEY_OUT"
_assert_not_contains "status --json: missing encoder emits no partial JSON" \
  '{"repo_type"' "$__SLEY_OUT"

if command -v jq >/dev/null 2>&1 || command -v python3 >/dev/null 2>&1; then
  _validate_json() {
    local data="$1"
    if command -v jq >/dev/null 2>&1; then
      printf '%s' "$data" | jq -e . >/dev/null
    else
      printf '%s' "$data" | python3 -c 'import json, sys; json.loads(sys.stdin.read())'
    fi
  }
  repo=$(_new_repo)
  tab_file=$'tab\tname.py'
  printf 'x = 1\n' >"$repo/$tab_file"
  (cd "$repo" && git add "$tab_file")
  _run_sley "$repo" changes --json --commit
  if _validate_json "$__SLEY_OUT"; then
    _pass "changes --json: tab filename emits valid JSON"
  else
    _fail "changes --json: tab filename emits valid JSON"
  fi

  # JSON escape coverage for quotes, backslashes, and a control byte. The
  # fallback path was historically untested and shipped broken control-byte
  # handling; this exercises whichever encoder backs `_repo_json_escape`.
  # Embedded-newline filenames are intentionally NOT covered here — they are
  # dropped with a stderr warning by `_repo_emit_safe_paths` because the
  # downstream bash pipeline (`sley secrets`, `sley fix`) is line-delimited
  # and cannot represent them safely. The dedicated regression test below
  # ("changed-file enumeration drops filenames with embedded newlines")
  # locks in that behavior.
  repo=$(_new_repo)
  for filename in $'quote".py' $'back\\slash.py' $'ctrl\x01char.py'; do
    printf 'x = 1\n' >"$repo/$filename"
    (cd "$repo" && git add -- "$filename") 2>/dev/null
  done
  _run_sley "$repo" changes --json --commit
  if _validate_json "$__SLEY_OUT"; then
    _pass "changes --json: quotes/backslash/control-byte emit valid JSON"
  else
    _fail "changes --json: quotes/backslash/control-byte emit valid JSON"
  fi
fi

mockbin=$(_mock_bin)
cat >"$mockbin/sl" <<'MOCK'
#!/usr/bin/env bash
if [[ "$1" == "root" ]]; then
  pwd
  exit 0
fi
exit 1
MOCK
chmod +x "$mockbin/sl"

PATH="$mockbin:$PATH" _run_sley "$repo" status --json
_assert_exit "status: fake sl root still detects git repo" 0 "$__SLEY_RC"
_assert_contains "status: fake sl root without metadata is git" '"repo_type":"git"' "$__SLEY_OUT"

outer=$(_tmpdir)
inner="$outer/nested"
mkdir -p "$outer/.sl" "$inner"
(
  cd "$inner" || exit 1
  export GIT_CONFIG_GLOBAL="$inner/.gitconfig-test"
  : >"$GIT_CONFIG_GLOBAL"
  git init -q
  git config user.email test@test.local
  git config user.name "Test User"
)
mockbin=$(_mock_bin)
cat >"$mockbin/sl" <<'MOCK'
#!/usr/bin/env bash
if [[ "$1" == "root" ]]; then
  printf '%s\n' "$SL_REPO"
  exit 0
fi
exit 1
MOCK
chmod +x "$mockbin/sl"

SL_REPO="$outer" PATH="$mockbin:$PATH" _run_sley "$inner" status --json
_assert_exit "status: nested git inside sl root exits 0" 0 "$__SLEY_RC"
_assert_contains "status: nested git root wins over outer sl root" '"repo_type":"git"' "$__SLEY_OUT"

explicit_git=$(_new_repo)
unrelated_sl=$(_tmpdir)
mkdir -p "$unrelated_sl/.sl"
mockbin=$(_mock_bin)
cat >"$mockbin/sl" <<'MOCK'
#!/usr/bin/env bash
case "$1" in
  root)
    printf '%s\n' "$SL_REPO"
    ;;
  log)
    printf 'slref'
    ;;
  status)
    ;;
esac
MOCK
chmod +x "$mockbin/sl"

__SLEY_OUT=$(
  cd "$unrelated_sl" || exit 1
  SL_REPO="$unrelated_sl" \
    PATH="$mockbin:$PATH" \
    GIT_DIR="$explicit_git/.git" \
    GIT_WORK_TREE="$explicit_git" \
    GIT_CONFIG_GLOBAL="$explicit_git/.gitconfig-test" \
    "$SLEY" status --json 2>&1
)
__SLEY_RC=$?
_assert_exit "status: explicit git env outside sl root exits 0" 0 "$__SLEY_RC"
_assert_contains "status: explicit git env outside sl root stays git" \
  '"repo_type":"git"' "$__SLEY_OUT"
_assert_contains "status: explicit git env reports git work tree" \
  "\"root\":\"$explicit_git\"" "$__SLEY_OUT"

repo=$(_tmpdir)
mkdir -p "$repo/.sl" "$repo/.sley"
mockbin=$(_mock_bin)
cat >"$mockbin/sl" <<'MOCK'
#!/usr/bin/env bash
case "$1" in
  root)
    printf '%s\n' "$SL_REPO"
    ;;
  log)
    case "$*" in
      *'{phase}'*) printf 'draft' ;;
      *'sort(draft() & ::., topo)'*) printf 'draftrev\n' ;;
      *) printf '' ;;
    esac
    ;;
  status)
    if printf '%s\n' "$*" | grep -q 'ui.color=never'; then
      color=0
    else
      color=1
    fi
    if printf '%s\n' "$*" | grep -q -- '--change draftrev'; then
      if [[ "$color" == "1" ]]; then
        printf '\033[31mdraft.py\033[0m\n'
      else
        printf 'draft.py\n'
      fi
    else
      if [[ "$color" == "1" ]]; then
        printf '\033[31mpending.py\033[0m\n'
      else
        printf 'pending.py\n'
      fi
    fi
    ;;
esac
MOCK
chmod +x "$mockbin/sl"
cat >"$repo/.sley/verify.json" <<'EOF'
{
  "rules": [
    {"paths": ["draft.py", "pending.py"], "commands": ["echo sl-color-test"]}
  ]
}
EOF

SL_REPO="$repo" PATH="$mockbin:$PATH" _run_sley "$repo" changes
_assert_exit "changes: sl draft context succeeds" 0 "$__SLEY_RC"
_assert_contains "changes: sl changed includes active draft commit" "draft.py" "$__SLEY_OUT"
_assert_contains "changes: sl changed includes pending files" "pending.py" "$__SLEY_OUT"

SL_REPO="$repo" PATH="$mockbin:$PATH" _run_sley "$repo" changes --commit
_assert_exit "changes: sl commit scope succeeds" 0 "$__SLEY_RC"
_assert_not_contains "changes: sl commit scope excludes active draft commit" "draft.py" "$__SLEY_OUT"
_assert_contains "changes: sl commit scope includes pending files" "pending.py" "$__SLEY_OUT"

SL_REPO="$repo" PATH="$mockbin:$PATH" _run_sley "$repo" verify
_assert_exit "verify registry: sl colorized status exits 0" 0 "$__SLEY_RC"
_assert_contains "verify registry: sl colorized status still maps command" "echo sl-color-test" "$__SLEY_OUT"

echo "=== sley: empty and invalid path scopes ==="

repo=$(_new_repo)
_run_sley "$repo" check
_assert_exit "check: empty scope exits 0" 0 "$__SLEY_RC"
_assert_contains "check: empty scope message" "no matching changed files" "$__SLEY_OUT"

no_sley_tools_path=$(_no_sley_tools_path)
PATH="$no_sley_tools_path" _run_sley "$repo" fix
_assert_exit "fix: empty scope does not require autoformat" 0 "$__SLEY_RC"
PATH="$no_sley_tools_path" _run_sley "$repo" secrets
_assert_exit "secrets: empty scope does not require gitleaks" 0 "$__SLEY_RC"

_run_sley "$repo" changes --path ../outside
_assert_exit "changes: path outside repo exits 2" 2 "$__SLEY_RC"
_assert_contains "changes: path outside repo reports error" "outside repo" "$__SLEY_OUT"

_run_sley "$repo" changes --path subdir
_assert_exit "changes: empty path inside repo exits 0" 0 "$__SLEY_RC"

mockbin=$(_mock_bin)
cat >"$mockbin/realpath" <<'MOCK'
#!/usr/bin/env bash
exit 1
MOCK
chmod +x "$mockbin/realpath"
PATH="$mockbin:$PATH" _run_sley "$repo" changes --path missing-subdir
_assert_exit "changes: missing in-repo path does not require GNU realpath" 0 "$__SLEY_RC"

_run_sley "$repo" changes --pending
_assert_exit "changes: old pending flag rejected" 2 "$__SLEY_RC"
_assert_contains "changes: old pending flag reports unknown option" "unknown option" "$__SLEY_OUT"

_run_sley "$repo" changes --staged
_assert_exit "changes: old staged flag rejected" 2 "$__SLEY_RC"
_assert_contains "changes: old staged flag reports unknown option" "unknown option" "$__SLEY_OUT"

_run_sley "$repo" changes --changed
_assert_exit "changes: old changed flag rejected" 2 "$__SLEY_RC"
_assert_contains "changes: old changed flag reports unknown option" "unknown option" "$__SLEY_OUT"

repo=$(_new_repo)
mkdir -p "$repo/sub" "$repo/other"
cat >"$repo/sub/in_scope.py" <<'EOF'
x = 1
EOF
cat >"$repo/other/out_scope.py" <<'EOF'
y = 1
