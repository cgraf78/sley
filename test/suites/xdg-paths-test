#!/usr/bin/env bash
# xdg-paths-test - XDG and explicit path precedence across Sley consumers.

# shellcheck disable=SC2030,SC2031 # Environment changes are intentionally isolated in probes.

set -o pipefail
export NO_COLOR=1

SLEY_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
SLEY_REPO_ROOT="$(cd -- "$SLEY_TEST_DIR/.." && pwd -P)"
SLEY="$SLEY_REPO_ROOT/bin/sley"
CACHE_HELPER="$SLEY_REPO_ROOT/lib/sley/verify-cache.py"

# shellcheck source=../helpers.sh
. "$SLEY_TEST_DIR/helpers.sh"
# shellcheck source=../../lib/sley/sley.sh
. "$SLEY_REPO_ROOT/lib/sley/sley.sh"

echo "=== sley: XDG path resolution ==="

home=$(_tmpdir)
resolved=$(
  result=""
  export HOME="$home" XDG_CONFIG_HOME=relative/config
  _sley_xdg_dir result XDG_CONFIG_HOME .config sley/extensions.d \
    "Sley extension directory"
  printf '%s' "$result"
)
_assert_eq "XDG config: relative root uses HOME fallback" \
  "$home/.config/sley/extensions.d" "$resolved"

resolved=$(
  result=""
  export HOME="$home" XDG_CONFIG_HOME=
  _sley_xdg_dir result XDG_CONFIG_HOME .config sley/extensions.d \
    "Sley extension directory"
  printf '%s' "$result"
)
_assert_eq "XDG config: empty root uses HOME fallback" \
  "$home/.config/sley/extensions.d" "$resolved"

missing_home_out=$(
  unset HOME
  XDG_CONFIG_HOME=relative/config \
    _sley_xdg_dir resolved XDG_CONFIG_HOME .config sley/extensions.d \
    "Sley extension directory" 2>&1
)
missing_home_rc=$?
_assert_exit "XDG config: missing HOME fails" 1 "$missing_home_rc"
_assert_contains "XDG config: missing HOME explains the unavailable roots" \
  "HOME is not set and XDG_CONFIG_HOME is not an absolute path" "$missing_home_out"

xdg_config=$(_tmpdir)/config
extension_dir="$xdg_config/sley/extensions.d"
mkdir -p "$extension_dir"
cat >"$extension_dir/80-xdg-test.sh" <<'EOF'
SLEY_XDG_EXTENSION_LOADED=absolute
EOF
xdg_extension_result=$(
  unset HOME SLEY_EXTENSION_DIR
  export XDG_CONFIG_HOME="$xdg_config"
  source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
  sley_hook_init
  printf '%s' "${SLEY_XDG_EXTENSION_LOADED:-missing}"
)
_assert_eq "XDG config: absolute root works without HOME" \
  "absolute" "$xdg_extension_result"

newline_extension_dir="$(_tmpdir)/extensions"$'\n'
mkdir -p "$newline_extension_dir"
cat >"$newline_extension_dir/80-newline-test.sh" <<'EOF'
SLEY_XDG_EXTENSION_LOADED=newline
EOF
newline_extension_result=$(
  unset HOME
  export XDG_CONFIG_HOME=relative/config
  export SLEY_EXTENSION_DIR="$newline_extension_dir"
  source "$SLEY_REPO_ROOT/lib/sley/sley.sh"
  sley_hook_init
  printf '%s' "${SLEY_XDG_EXTENSION_LOADED:-missing}"
)
_assert_eq "extension override: trailing newline path reaches the consumer unchanged" \
  "newline" "$newline_extension_result"

repo=$(_tmpdir)
repo=$(cd "$repo" && pwd -P)
git -C "$repo" init -q
git -C "$repo" config user.email test@test.local
git -C "$repo" config user.name "Test User"
git -C "$repo" config commit.gpgsign false
mkdir -p "$repo/.hooks"
git -C "$repo" config core.hooksPath "$repo/.hooks"
printf 'initial\n' >"$repo/app.txt"
git -C "$repo" add app.txt
git -C "$repo" commit -q -m seed
printf 'changed\n' >>"$repo/app.txt"
xdg_bin=$(_mock_bin)
ln -s /usr/bin/git "$xdg_bin/git"

action_log=$(_tmpdir)/actions.log
: >"$action_log"
cat >"$xdg_bin/autoformat" <<'EOF'
#!/usr/bin/env bash
printf 'format:%s\n' "$*" >>"$ACTION_LOG"
EOF
cat >"$xdg_bin/autolint" <<'EOF'
#!/usr/bin/env bash
printf 'lint:%s\n' "$*" >>"$ACTION_LOG"
EOF
chmod +x "$xdg_bin/autoformat" "$xdg_bin/autolint"

for command in fix check; do
  command_out=$(
    cd "$repo" || exit 1
    env -u HOME -u SLEY_EXTENSION_DIR ACTION_LOG="$action_log" \
      XDG_CONFIG_HOME=relative/config XDG_CACHE_HOME="$(_tmpdir)/cache" \
      GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
      "$SLEY" "$command" 2>&1
  )
  command_rc=$?
  _assert_exit "$command init: unresolved XDG fallback fails closed" 1 "$command_rc"
  _assert_contains "$command init: failure explains extension path" \
    "cannot resolve Sley extension directory" "$command_out"
done
_assert_eq "fix/check init: actions do not run after failure" "" "$(cat "$action_log")"

clean_repo=$(_tmpdir)
git -C "$clean_repo" init -q
git -C "$clean_repo" config user.email test@test.local
git -C "$clean_repo" config user.name "Test User"
git -C "$clean_repo" config commit.gpgsign false
mkdir -p "$clean_repo/.hooks"
git -C "$clean_repo" config core.hooksPath "$clean_repo/.hooks"
printf 'clean\n' >"$clean_repo/clean.txt"
git -C "$clean_repo" add clean.txt
git -C "$clean_repo" commit -q -m seed
for command in fix check; do
  command_out=$(
    cd "$clean_repo" || exit 1
    env -u HOME -u SLEY_EXTENSION_DIR ACTION_LOG="$action_log" \
      XDG_CONFIG_HOME=relative/config XDG_CACHE_HOME="$(_tmpdir)/cache" \
      GIT_CONFIG_GLOBAL="$clean_repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
      "$SLEY" "$command" 2>&1
  )
  command_rc=$?
  _assert_exit "$command empty selection: config resolution stays lazy" 0 "$command_rc"
  _assert_contains "$command empty selection: reports no work" \
    "no matching changed files" "$command_out"
  _assert_not_contains "$command empty selection: omits config errors" \
    "cannot resolve Sley extension directory" "$command_out"
done

argument_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_EXTENSION_DIR XDG_CONFIG_HOME=relative/config \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" fix --bogus 2>&1
)
argument_rc=$?
_assert_exit "argument validation: invalid fix option remains a usage error" 2 "$argument_rc"
_assert_contains "argument validation: invalid fix option is reported" \
  "unknown option: --bogus" "$argument_out"
_assert_not_contains "argument validation: invalid fix option needs no config" \
  "cannot resolve Sley extension directory" "$argument_out"

argument_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_EXTENSION_DIR XDG_CONFIG_HOME=relative/config \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" hook format-file 2>&1
)
argument_rc=$?
_assert_exit "hook argument validation: missing file remains a usage error" 2 "$argument_rc"
_assert_contains "hook argument validation: missing file is reported" \
  "hook format-file requires a file" "$argument_out"
_assert_not_contains "hook argument validation: missing file needs no config" \
  "cannot resolve Sley extension directory" "$argument_out"

help_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_EXTENSION_DIR XDG_CONFIG_HOME=relative/config \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" hook --help 2>&1
)
help_rc=$?
_assert_exit "hook help: remains config-independent" 0 "$help_rc"
_assert_contains "hook help: prints usage" "Usage: sley hook COMMAND" "$help_out"

_probe_hook_init_failure() {
  local label="$1" hook_out hook_rc
  shift
  : >"$action_log"
  hook_out=$(
    cd "$repo" || exit 1
    # shellcheck disable=SC2016 # Variables expand in the isolated child shell.
    env -u HOME -u SLEY_EXTENSION_DIR ACTION_LOG="$action_log" \
      XDG_CONFIG_HOME=relative/config GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
      PATH="$xdg_bin:$PATH" bash -c '
        source "$1/lib/sley/sley.sh"
        shift
        sley_hook_changed_files() { printf "changed-files\n" >>"$ACTION_LOG"; }
        sley_hook_format_file() { printf "format-file\n" >>"$ACTION_LOG"; }
        sley_hook_lint_file() { printf "lint-file\n" >>"$ACTION_LOG"; }
        sley_hook_format() { printf "format\n" >>"$ACTION_LOG"; }
        sley_hook_lint() { printf "lint\n" >>"$ACTION_LOG"; }
        sley_hook_validate() { printf "validate\n" >>"$ACTION_LOG"; }
        sley_hook "$@" <<<"app.txt"
      ' _ "$SLEY_REPO_ROOT" "$@" 2>&1
  )
  hook_rc=$?
  _assert_exit "hook $label: initialization failure propagates" 1 "$hook_rc"
  _assert_contains "hook $label: failure explains extension path" \
    "cannot resolve Sley extension directory" "$hook_out"
  _assert_eq "hook $label: action does not run after failure" "" "$(cat "$action_log")"
}

_probe_hook_init_failure changed-files changed-files
_probe_hook_init_failure format-file format-file app.txt
_probe_hook_init_failure lint-file lint-file --json app.txt
_probe_hook_init_failure format format --stdin
_probe_hook_init_failure lint lint --stdin
_probe_hook_init_failure validate validate

ready_tmp=$(_tmpdir)
: >"$action_log"
ready_out=$(
  cd "$repo" || exit 1
  # shellcheck disable=SC2016 # Variables expand in the isolated child shell.
  env -u HOME -u SLEY_EXTENSION_DIR ACTION_LOG="$action_log" \
    XDG_CONFIG_HOME=relative/config GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
    PATH="$xdg_bin:$PATH" TMPDIR="$ready_tmp" bash -c '
      source "$1/lib/sley/sley.sh"
      _sley_selected_files_for_filters() { printf "selection\n" >>"$ACTION_LOG"; }
      sley_ext_ready_phases() { printf "extensions\n" >>"$ACTION_LOG"; }
      _sley_ready_run_phase() { printf "phase\n" >>"$ACTION_LOG"; }
      sley_ready
    ' _ "$SLEY_REPO_ROOT" 2>&1
)
ready_rc=$?
_assert_exit "ready init: unresolved XDG fallback fails closed" 1 "$ready_rc"
_assert_contains "ready init: failure explains extension path" \
  "cannot resolve Sley extension directory" "$ready_out"
_assert_not_contains "ready init: failure occurs before selection progress" \
  "selecting changed files" "$ready_out"
_assert_eq "ready init: selection, extensions, and phases do not run" "" "$(cat "$action_log")"
ready_cache_count=$(
  shopt -s nullglob
  ready_cache_files=("$ready_tmp"/sley-ready-selected.*)
  printf '%s' "${#ready_cache_files[@]}"
)
_assert_eq "ready init: failure leaves no selected-file cache" "0" "$ready_cache_count"

help_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_EXTENSION_DIR XDG_CONFIG_HOME=relative/config \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" ready --help 2>&1
)
help_rc=$?
_assert_exit "ready help: remains config-independent" 0 "$help_rc"
_assert_contains "ready help: prints usage" "Usage: sley ready" "$help_out"

xdg_config=$(_tmpdir)/config
mkdir -p "$xdg_config/sley/verify.d"
cat >"$xdg_config/sley/verify.d/xdg.json" <<EOF
{"repos":[{"match":{"root":"$repo"},"rules":[{"paths":["app.txt"],"commands":["echo xdg-verify"]}]}]}
EOF
verify_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_VERIFY_CONFIG \
    XDG_CONFIG_HOME="$xdg_config" XDG_CACHE_HOME="$(_tmpdir)/cache" \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" verify 2>&1
)
verify_rc=$?
_assert_exit "verify registry: absolute XDG config works without HOME" 0 "$verify_rc"
_assert_contains "verify registry: XDG config reaches registry consumer" \
  "echo xdg-verify" "$verify_out"

newline_config="$(_tmpdir)/verify.json"$'\n'
explicit_extension_dir=$(_tmpdir)/extensions
mkdir -p "$explicit_extension_dir"
cat >"$newline_config" <<EOF
{"repos":[{"match":{"root":"$repo"},"rules":[{"paths":["app.txt"],"commands":["echo newline-verify"]}]}]}
EOF
verify_out=$(
  cd "$repo" || exit 1
  env -u HOME SLEY_VERIFY_CONFIG="$newline_config" \
    SLEY_EXTENSION_DIR="$explicit_extension_dir" XDG_CONFIG_HOME=relative/config \
    XDG_CACHE_HOME="$(_tmpdir)/cache" GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
    PATH="$xdg_bin:$PATH" "$SLEY" verify --json 2>&1
)
verify_rc=$?
_assert_exit "verify override: trailing newline path works without HOME" 0 "$verify_rc"
_assert_contains "verify override: exact path reaches registry consumer" \
  "echo newline-verify" "$verify_out"
expected_source_hex=$(printf '%s' "$newline_config" | od -An -tx1 | tr -d ' \n')
actual_source_hex=$(printf '%s' "$verify_out" | python3 -c '
import json
import sys

payload = json.load(sys.stdin)
command = next(item for item in payload["commands"] if item["command"] == "echo newline-verify")
print(command["source_contexts"][0]["source"].encode().hex())
')
_assert_eq "verify override: structured source preserves trailing newline" \
  "$expected_source_hex" "$actual_source_hex"

verify_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_EXTENSION_DIR SLEY_VERIFY_CONFIG="$newline_config" \
    XDG_CONFIG_HOME=relative/config XDG_CACHE_HOME="$(_tmpdir)/cache" \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" PATH="$xdg_bin:$PATH" \
    "$SLEY" verify 2>&1
)
verify_rc=$?
_assert_exit "verify extensions: unresolved XDG fallback blocks discovery" 1 "$verify_rc"
_assert_contains "verify extensions: unresolved fallback has actionable error" \
  "cannot resolve Sley extension directory" "$verify_out"

verify_out=$(
  cd "$repo" || exit 1
  env -u HOME -u SLEY_VERIFY_CONFIG SLEY_EXTENSION_DIR="$explicit_extension_dir" \
    XDG_CONFIG_HOME=relative/config \
    XDG_CACHE_HOME="$(_tmpdir)/cache" GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
    PATH="$xdg_bin:$PATH" "$SLEY" verify 2>&1
)
verify_rc=$?
_assert_exit "verify registry: relative XDG without HOME fails" 1 "$verify_rc"
_assert_contains "verify registry: missing fallback has actionable error" \
  "cannot resolve Sley verify registry directory" "$verify_out"

cache_root() {
  python3 -c 'import json,sys; print(json.load(sys.stdin)["root"].encode().hex())'
}

absolute_cache=$(_tmpdir)/cache
cache_out=$(env -u HOME -u SLEY_VERIFY_CACHE_DIR XDG_CACHE_HOME="$absolute_cache" \
  python3 "$CACHE_HELPER" stats)
_assert_eq "XDG cache: absolute root works without HOME" \
  "$(printf '%s' "$absolute_cache/sley/verify" | od -An -tx1 | tr -d ' \n')" \
  "$(printf '%s' "$cache_out" | cache_root)"

home=$(_tmpdir)
cache_out=$(env -u SLEY_VERIFY_CACHE_DIR HOME="$home" XDG_CACHE_HOME=relative/cache \
  python3 "$CACHE_HELPER" stats)
_assert_eq "XDG cache: relative root uses HOME fallback" \
  "$(printf '%s' "$home/.cache/sley/verify" | od -An -tx1 | tr -d ' \n')" \
  "$(printf '%s' "$cache_out" | cache_root)"

cache_out=$(env -u SLEY_VERIFY_CACHE_DIR HOME="$home" XDG_CACHE_HOME= \
  python3 "$CACHE_HELPER" stats)
_assert_eq "XDG cache: empty root uses HOME fallback" \
  "$(printf '%s' "$home/.cache/sley/verify" | od -An -tx1 | tr -d ' \n')" \
  "$(printf '%s' "$cache_out" | cache_root)"

newline_cache="$(_tmpdir)/cache"$'\n'
cache_out=$(env -u HOME SLEY_VERIFY_CACHE_DIR="$newline_cache" \
  XDG_CACHE_HOME=relative/cache python3 "$CACHE_HELPER" stats)
_assert_eq "cache override: trailing newline path reaches the consumer unchanged" \
  "$(printf '%s' "$newline_cache" | od -An -tx1 | tr -d ' \n')" \
  "$(printf '%s' "$cache_out" | cache_root)"

cache_out=$(env -u HOME -u SLEY_VERIFY_CACHE_DIR XDG_CACHE_HOME=relative/cache \
  python3 "$CACHE_HELPER" stats 2>&1)
cache_rc=$?
_assert_exit "XDG cache: relative root without HOME fails" 1 "$cache_rc"
_assert_contains "XDG cache: missing fallback has actionable error" \
  "cannot resolve Sley verify cache directory" "$cache_out"

_test_summary
