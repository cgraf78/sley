#!/usr/bin/env bash
# Verify that the PATH-visible workflow command has a manual page.

set -o pipefail
export NO_COLOR=1

SLEY_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
SLEY_REPO_ROOT="$(cd -- "$SLEY_TEST_DIR/.." && pwd -P)"

# shellcheck source=../helpers.sh
. "$SLEY_TEST_DIR/helpers.sh"

echo "=== sley: manpages ==="

while IFS= read -r command; do
  page="$SLEY_REPO_ROOT/man/man1/$command.1"
  _assert_file_exists "manpage exists: $command" "$page"
  content=$(cat "$page")
  _assert_contains "manpage NAME section: $command" ".SH NAME" "$content"
  _assert_contains "manpage names command: $command" "$command \\" "$content"
done < <(
  git -C "$SLEY_REPO_ROOT" ls-files -- 'bin/*' |
    xargs -n 1 basename |
    sort
)

_assert_contains "manpage documents verify bridge" "Checkrun verify bridge" "$content"

_test_summary
