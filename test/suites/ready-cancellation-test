#!/usr/bin/env bash
# ready-cancellation-test - signal cleanup and sourced-shell discipline.

set -o pipefail
export NO_COLOR=1

SLEY_TEST_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
SLEY_REPO_ROOT="$(cd -- "$SLEY_TEST_DIR/.." && pwd -P)"
export SLEY_REPO_ROOT

# shellcheck disable=SC1091 # Resolved from the suite's runtime location.
. "$SLEY_TEST_DIR/helpers.sh"

_new_ready_repo() {
  local repo
  repo=$(_tmpdir)
  (
    cd "$repo" || exit 1
    export GIT_CONFIG_GLOBAL="$repo/.gitconfig-test"
    : >"$GIT_CONFIG_GLOBAL"
    git init -q
    git config user.email test@test.local
    git config user.name "Test User"
    git config commit.gpgsign false
    printf 'ready\n' >tracked.txt
    git add tracked.txt
    git commit -q -m seed
  )
  printf '%s\n' "$repo"
}

_result_value() {
  local key="$1" content="$2"
  printf '%s\n' "$content" | awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}'
}

_millis_below() {
  local value="$1" limit="$2"
  if [[ -n "$value" && "$value" != *[!0-9]* ]] && ((value < limit)); then
    printf 'yes\n'
  else
    printf 'no\n'
  fi
}

repo=$(_new_ready_repo)
home=$(_tmpdir)
config=$(_tmpdir)
sync_dir=$(_tmpdir)
ready_tmp=$(_tmpdir)
mkdir -p "$config/sley/extensions.d"

system_ps=""
if [[ ! -r /proc/self/stat ]]; then
  for ps_candidate in /bin/ps /usr/bin/ps; do
    if [[ -x "$ps_candidate" ]]; then
      system_ps=$ps_candidate
      break
    fi
  done
  if [[ -z "$system_ps" ]]; then
    system_ps=$(command -v ps 2>/dev/null || true)
  fi
  [[ -x "$system_ps" ]] || {
    echo "ready-cancellation-test: ps is required on systems without procfs" >&2
    exit 1
  }
  export SLEY_READY_SYSTEM_PS="$system_ps"
fi

cat >"$config/sley/extensions.d/80-ready-cancellation.sh" <<'EXTENSION'
sley_ext_ready_phases() {
  if [[ "${SLEY_READY_TEST_MODE:-}" == "interactive" ]]; then
    : >"$SLEY_READY_SYNC/interactive.waiting"
    IFS= read -r terminal_input
    printf '%s\n' "$terminal_input" >"$SLEY_READY_SYNC/interactive.input"
  fi
  printf '%s\n' phase-a phase-b
}

sley_hook_format_file() {
  case "${SLEY_READY_TEST_MODE:-}" in
    format-long)
      printf 'formatted by interrupted formatter\n' >"$1"
      "$SLEY_READY_FORMATTER"
      : >"$SLEY_READY_SYNC/formatter.runner-resumed"
      ;;
    format-delayed)
      printf 'formatted by interrupted formatter\n' >"$1"
      : >"$SLEY_READY_SYNC/formatter.runner-waiting"
      while [[ ! -e "$SLEY_READY_SYNC/formatter.allow-spawn" ]]; do :; done
      "$SLEY_READY_FORMATTER"
      : >"$SLEY_READY_SYNC/formatter.runner-resumed"
      ;;
  esac
}

sley_ext_ready_phase() {
  local phase="$1"
  case "${SLEY_READY_TEST_MODE:-normal}" in
    normal)
      printf '%s complete\n' "$phase"
      ;;
    failure)
      if [[ "$phase" == "phase-a" ]]; then
        printf '%s blocked\n' "$phase" >&2
        return 1
      fi
      printf '%s complete\n' "$phase"
      ;;
    stdin-probe)
      if IFS= read -r phase_input; then
        printf '%s\n' "$phase_input" >"$SLEY_READY_SYNC/$phase.stdin"
      else
        printf 'eof\n' >"$SLEY_READY_SYNC/$phase.stdin"
      fi
      ;;
    long)
      printf '%s\n' "$BASHPID" >"$SLEY_READY_SYNC/$phase.pid"
      : >"$SLEY_READY_SYNC/$phase.started"
      while :; do
        :
      done
      ;;
    descendant)
      printf '%s\n' "$BASHPID" >"$SLEY_READY_SYNC/$phase.pid"
      sleep 300 &
      descendant_pid=$!
      printf '%s\n' "$descendant_pid" >"$SLEY_READY_SYNC/$phase.descendant.pid"
      : >"$SLEY_READY_SYNC/$phase.started"
      wait "$descendant_pid"
      ;;
    term-cleanup)
      printf '%s\n' "$BASHPID" >"$SLEY_READY_SYNC/$phase.pid"
      trap 'sleep 0.1; : >"$SLEY_READY_SYNC/'"$phase"'.term-cleanup"; exit 0' TERM
      : >"$SLEY_READY_SYNC/$phase.started"
      while :; do
        :
      done
      ;;
  esac
}
EXTENSION

formatter=$(_tmpdir)/term-ignoring-formatter
cat >"$formatter" <<'FORMATTER'
#!/usr/bin/env bash

trap '' INT TERM
printf '%s\n' "$BASHPID" >"$SLEY_READY_SYNC/formatter.pid"
: >"$SLEY_READY_SYNC/formatter.started"
while :; do
  :
done
FORMATTER
chmod +x "$formatter"
export SLEY_READY_FORMATTER="$formatter"

harness=$(_tmpdir)/ready-source-harness
cat >"$harness" <<'HARNESS'
#!/usr/bin/env bash

root="$1"
output="$2"
result="$3"

# shellcheck disable=SC1090 # The test supplies the checkout under test.
source "$root/lib/sley/sley.sh"

if [[ "${SLEY_READY_TEST_NO_IDENTITY:-0}" == "1" ]]; then
  _sley_ready_process_identity() { return 1; }
  _sley_ready_process_tree() { return 1; }
fi
if [[ "${SLEY_READY_TEST_NO_PS:-0}" == "1" ]]; then
  _sley_ready_ps() { return 127; }
fi
if [[ "${SLEY_READY_TEST_NO_GROUP:-0}" == "1" ]]; then
  _sley_ready_process_group() { return 1; }
fi
if [[ -n "${SLEY_READY_TEST_IDENTITY_LOST_FILE:-}" ]]; then
  eval "$(declare -f _sley_ready_process_identity | sed \
    '1s/_sley_ready_process_identity/_sley_ready_saved_process_identity/')"
  _sley_ready_process_identity() {
    [[ ! -e "$SLEY_READY_TEST_IDENTITY_LOST_FILE" ]] || return 1
    _sley_ready_saved_process_identity "$@"
  }
fi
if [[ "${SLEY_READY_TEST_MODE:-}" == "format-delayed" ]]; then
  _sley_ready_wait_for_processes() {
    local process_list="$1" attempts="$2" attempt process_pid process_identity any_alive
    if [[ ! -e "$SLEY_READY_SYNC/cleanup-wait-entered" ]]; then
      : >"$SLEY_READY_SYNC/cleanup-wait-entered"
      : >"$SLEY_READY_SYNC/formatter.allow-spawn"
      for ((attempt = 0; attempt < 100; attempt++)); do
        [[ ! -e "$SLEY_READY_SYNC/formatter.started" ]] || break
        sleep 0.01
      done
    fi
    for ((attempt = 0; attempt < attempts; attempt++)); do
      any_alive=0
      while IFS=$'\t' read -r process_pid process_identity; do
        [[ -n "$process_pid" ]] || continue
        if _sley_ready_process_is_same "$process_pid" "$process_identity"; then
          any_alive=1
          break
        fi
      done <<<"$process_list"
      [[ "$any_alive" == "1" ]] || return 0
      sleep 0.05
    done
    return 1
  }
fi

trap 'printf "INT\n" >>"$SLEY_READY_TRAP_LOG"' INT
trap 'printf "TERM\n" >>"$SLEY_READY_TRAP_LOG"' TERM
trap 'printf "HUP\n" >>"$SLEY_READY_TRAP_LOG"' HUP
before_int=$(trap -p INT)
before_term=$(trap -p TERM)
before_hup=$(trap -p HUP)
before_options=$-

ready_args=(
  --exclude status
  --exclude check
  --exclude secrets
  --exclude verify
)
if [[ "${SLEY_READY_TEST_NO_IDENTITY:-0}" == "1" || "${SLEY_READY_TEST_NO_GROUP:-0}" == "1" ]]; then
  ready_args=(--quiet "${ready_args[@]}")
fi
if [[ "${SLEY_READY_TEST_MODE:-}" == format-* ]]; then
  ready_args=(--fix --commit "${ready_args[@]}")
fi
sley_ready "${ready_args[@]}" >"$output" 2>&1
ready_rc=$?

after_int=$(trap -p INT)
after_term=$(trap -p TERM)
after_hup=$(trap -p HUP)
after_options=$-
traps_restored=no
if [[ "$before_int" == "$after_int" &&
  "$before_term" == "$after_term" &&
  "$before_hup" == "$after_hup" ]]; then
  traps_restored=yes
fi

options_restored=no
[[ "$before_options" == "$after_options" ]] && options_restored=yes

cleanup_globals_absent=yes
for name in \
  _sley_ready_cleanup_done \
  _sley_ready_cleanup_active \
  _sley_ready_launching_child \
  _sley_ready_pending_status \
  phase_pids \
  phase_stdout_files \
  phase_stderr_files \
  SLEY_CALLER \
  SLEY_SCOPED \
  _SLEY_SELECTED_FILES_CACHE_FILE \
  _SLEY_SELECTED_FILES_CACHE_KEY; do
  if declare -p "$name" >/dev/null 2>&1; then
    cleanup_globals_absent=no
  fi
done

artifact_count=0
for artifact in "${TMPDIR:-/tmp}"/sley-ready-*; do
  [[ -e "$artifact" ]] || continue
  artifact_count=$((artifact_count + 1))
done
fix_backup_count=0
for artifact in "${TMPDIR:-/tmp}"/sley-fix-bak.*; do
  [[ -e "$artifact" ]] || continue
  fix_backup_count=$((fix_backup_count + 1))
done

{
  printf 'ready_rc=%s\n' "$ready_rc"
  printf 'traps_restored=%s\n' "$traps_restored"
  printf 'options_restored=%s\n' "$options_restored"
  printf 'cleanup_globals_absent=%s\n' "$cleanup_globals_absent"
  printf 'artifact_count=%s\n' "$artifact_count"
  printf 'fix_backup_count=%s\n' "$fix_backup_count"
} >"$result"
HARNESS
chmod +x "$harness"

_run_sourced_ready() {
  local mode="$1" output="$2" result="$3" trap_log="$4"
  (
    cd "$repo" || exit 1
    HOME="$home" \
      XDG_CONFIG_HOME="$config" \
      XDG_CACHE_HOME="$home/cache" \
      GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
      SLEY_READY_TEST_MODE="$mode" \
      SLEY_READY_SYNC="$sync_dir" \
      SLEY_READY_FORMATTER="$formatter" \
      SLEY_READY_TRAP_LOG="$trap_log" \
      TMPDIR="$ready_tmp" \
      bash --noprofile --norc "$harness" "$SLEY_REPO_ROOT" "$output" "$result"
  )
}

echo "=== sley: ready normal and failure cleanup ==="

help_harness=$(_tmpdir)/ready-help-harness
cat >"$help_harness" <<'HARNESS'
#!/usr/bin/env bash

root="$1"

# shellcheck disable=SC1090 # The test supplies the checkout under test.
source "$root/lib/sley/sley.sh"
_sley_ready_process_identity() { return 1; }
sley_ready --help
HARNESS
chmod +x "$help_harness"
help_output=$(TMPDIR=/definitely/missing/sley-ready-test \
  bash --noprofile --norc "$help_harness" "$SLEY_REPO_ROOT" 2>&1)
help_rc=$?
_assert_eq "ready help: bypasses supervisor setup" "0" "$help_rc"
_assert_contains "ready help: remains available without process identity or TMPDIR" \
  "Usage: sley ready" "$help_output"

normal_output=$(_tmpdir)/normal.out
normal_result=$(_tmpdir)/normal.result
normal_trap_log=$(_tmpdir)/normal.traps
_run_sourced_ready normal "$normal_output" "$normal_result" "$normal_trap_log"
normal_data=$(cat "$normal_result")
_assert_eq "ready normal: exits successfully" "0" "$(_result_value ready_rc "$normal_data")"
_assert_eq "ready normal: restores caller traps" "yes" "$(_result_value traps_restored "$normal_data")"
_assert_eq "ready normal: preserves caller shell options" "yes" "$(_result_value options_restored "$normal_data")"
_assert_eq "ready normal: leaks no cleanup globals" "yes" "$(_result_value cleanup_globals_absent "$normal_data")"
_assert_eq "ready normal: leaves no temporary artifacts" "0" "$(_result_value artifact_count "$normal_data")"
normal_phase_a_line=$(awk '/^phase-a:/ {print NR; exit}' "$normal_output")
normal_phase_b_line=$(awk '/^phase-b:/ {print NR; exit}' "$normal_output")
if [[ -n "$normal_phase_a_line" && -n "$normal_phase_b_line" &&
  "$normal_phase_a_line" -lt "$normal_phase_b_line" ]]; then
  _pass "ready normal: reports phases in declaration order"
else
  _fail "ready normal: phase report order changed"
fi
if grep -Eq '^\[[0-9]+\].*(Done|Terminated|Exit)' "$normal_output"; then
  _fail "ready normal: isolated implementation leaked a job-status notification"
else
  _pass "ready normal: emits no job-status notification"
fi

stdin_harness=$(_tmpdir)/ready-stdin-harness
cat >"$stdin_harness" <<'HARNESS'
#!/usr/bin/env bash

root="$1"
result="$2"

# shellcheck disable=SC1090 # The test supplies the checkout under test.
source "$root/lib/sley/sley.sh"
sley_ready \
  --exclude status \
  --exclude check \
  --exclude secrets \
  --exclude verify >/dev/null 2>&1
ready_rc=$?
caller_input=""
IFS= read -r caller_input
{
  printf 'ready_rc=%s\n' "$ready_rc"
  printf 'caller_input=%s\n' "$caller_input"
} >"$result"
HARNESS
chmod +x "$stdin_harness"

echo "=== sley: concurrent phases do not inherit caller stdin ==="

rm -f "$sync_dir"/phase-*.stdin 2>/dev/null || true
stdin_result=$(_tmpdir)/stdin.result
printf 'caller-payload\n' | (
  cd "$repo" || exit 1
  HOME="$home" \
    XDG_CONFIG_HOME="$config" \
    XDG_CACHE_HOME="$home/cache" \
    GIT_CONFIG_GLOBAL="$repo/.gitconfig-test" \
    SLEY_READY_TEST_MODE=stdin-probe \
    SLEY_READY_SYNC="$sync_dir" \
    TMPDIR="$ready_tmp" \
    bash --noprofile --norc "$stdin_harness" "$SLEY_REPO_ROOT" "$stdin_result"
)
stdin_data=$(cat "$stdin_result")
_assert_eq "ready phase stdin: run succeeds" "0" "$(_result_value ready_rc "$stdin_data")"
_assert_eq "ready phase stdin: caller retains piped input" \
  "caller-payload" "$(_result_value caller_input "$stdin_data")"
_assert_eq "ready phase stdin: phase A receives EOF" "eof" "$(cat "$sync_dir/phase-a.stdin")"
_assert_eq "ready phase stdin: phase B receives EOF" "eof" "$(cat "$sync_dir/phase-b.stdin")"

interactive_driver=$(_tmpdir)/ready-interactive-driver.py
interactive_cancel_harness=$(_tmpdir)/ready-interactive-cancel-harness
cat >"$interactive_cancel_harness" <<'HARNESS'
#!/usr/bin/env bash

root="$1"
result="$2"

# shellcheck disable=SC1090 # The test supplies the checkout under test.
source "$root/lib/sley/sley.sh"

# Widen the interval in which a terminal-delivered INT and the wrapper's
# forwarded INT can overlap cleanup. The renamed function is the real cleanup,
# so the test still verifies worktree restoration and artifact ownership.
eval "$(declare -f _sley_ready_cleanup | sed '1s/_sley_ready_cleanup/_sley_ready_cleanup_original/')"
_sley_ready_cleanup() {
  : >"$SLEY_READY_SYNC/interactive-cleanup.started"
  sleep 1
  _sley_ready_cleanup_original
  : >"$SLEY_READY_SYNC/interactive-cleanup.done"
}

sley_ready \
  --fix \
  --commit \
  --exclude status \
  --exclude check \
  --exclude secrets \
  --exclude verify >/dev/null 2>&1
ready_rc=$?

artifact_count=0
for artifact in "${TMPDIR:-/tmp}"/sley-ready-*; do
  [[ -e "$artifact" ]] || continue
  artifact_count=$((artifact_count + 1))
done
fix_backup_count=0
for artifact in "${TMPDIR:-/tmp}"/sley-fix-bak.*; do
  [[ -e "$artifact" ]] || continue
  fix_backup_count=$((fix_backup_count + 1))
done

{
  printf 'ready_rc=%s\n' "$ready_rc"
  printf 'cleanup_done=%s\n' "$([[ -e "$SLEY_READY_SYNC/interactive-cleanup.done" ]] && printf yes || printf no)"
  printf 'artifact_count=%s\n' "$artifact_count"
  printf 'fix_backup_count=%s\n' "$fix_backup_count"
} >"$result"
HARNESS
chmod +x "$interactive_cancel_harness"

cat >"$interactive_driver" <<'PYTHON'
import atexit
import fcntl
import os
import pty
import select
import signal
import subprocess
import sys
import termios
import time

(
    bash_command,
    root,
    repo,
    home,
    config,
    cache,
    tmpdir,
    sync_dir,
    formatter,
    scenario,
    cancel_harness,
    cancel_result,
) = sys.argv[1:]


process = None
owned_pid = None
owned_session = None
owned_pids = set()
owned_groups = set()
driver_session = os.getsid(0)
diagnostic_path = os.path.join(sync_dir, f"interactive-driver-{scenario}.diagnostics")


def record_diagnostic(message):
    with open(diagnostic_path, "a", encoding="utf-8") as diagnostic_file:
        diagnostic_file.write(f"{message}\n")


def remember_owned_pid(pid):
    if owned_session is None:
        return False
    try:
        if os.getsid(pid) != owned_session:
            return False
        owned_pids.add(pid)
        owned_groups.add(os.getpgid(pid))
        return True
    except OSError:
        return False


def discover_owned_processes():
    if os.path.isdir("/proc"):
        try:
            entries = os.scandir("/proc")
        except OSError:
            return
        with entries:
            for entry in entries:
                if entry.name.isdigit():
                    remember_owned_pid(int(entry.name))
        return
    ps_command = os.environ.get("SLEY_READY_SYSTEM_PS")
    if not ps_command:
        return
    try:
        output = subprocess.check_output(
            [ps_command, "-A", "-o", "pid="],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except (OSError, subprocess.SubprocessError):
        return
    for pid_text in output.split():
        if pid_text.isdigit() and int(pid_text) != os.getpid():
            remember_owned_pid(int(pid_text))


def remember_foreground_group(terminal_fd):
    try:
        foreground_group = os.tcgetpgrp(terminal_fd)
        if os.getsid(foreground_group) == owned_session:
            owned_groups.add(foreground_group)
            return True
    except OSError:
        pass
    return False


def kill_owned_processes():
    if owned_session is None or owned_session == driver_session:
        return
    for _ in range(3):
        discover_owned_processes()
        for pid in tuple(owned_pids):
            remember_owned_pid(pid)
        for process_group in tuple(owned_groups):
            try:
                os.killpg(process_group, signal.SIGKILL)
            except OSError:
                pass
        for pid in tuple(owned_pids):
            try:
                if os.getsid(pid) == owned_session:
                    os.kill(pid, signal.SIGKILL)
            except OSError:
                pass
        time.sleep(0.02)


def cleanup_owned_session():
    if owned_session is not None:
        kill_owned_processes()
    elif owned_pid is not None:
        try:
            os.killpg(owned_pid, signal.SIGKILL)
        except OSError:
            pass


def interrupted(_signal_number, _frame):
    raise SystemExit(1)


atexit.register(cleanup_owned_session)
handled_signals = (signal.SIGINT, signal.SIGTERM, signal.SIGHUP)
for handled_signal in handled_signals:
    signal.signal(handled_signal, interrupted)


env = os.environ.copy()
env.update(
    {
        "HOME": home,
        "XDG_CONFIG_HOME": config,
        "XDG_CACHE_HOME": cache,
        "GIT_CONFIG_GLOBAL": os.path.join(repo, ".gitconfig-test"),
        "SLEY_READY_TEST_MODE": "format-long" if scenario == "cancel" else "interactive",
        "SLEY_READY_SYNC": sync_dir,
        "SLEY_READY_FORMATTER": formatter,
        "TMPDIR": tmpdir,
        "PS1": "",
        "PROMPT_COMMAND": "",
    }
)

previous_mask = signal.pthread_sigmask(signal.SIG_BLOCK, handled_signals)
terminal_fd, child_terminal_fd = pty.openpty()
record_diagnostic(f"driver_session={driver_session}")
record_diagnostic("pty_opened=yes")


def prepare_child():
    os.setsid()
    fcntl.ioctl(child_terminal_fd, termios.TIOCSCTTY, 0)
    os.tcsetpgrp(child_terminal_fd, os.getpgrp())
    signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)


process = subprocess.Popen(
    [bash_command, "--noprofile", "--norc", "-i"],
    cwd=repo,
    env=env,
    stdin=child_terminal_fd,
    stdout=child_terminal_fd,
    stderr=child_terminal_fd,
    preexec_fn=prepare_child,
)
os.close(child_terminal_fd)
pid = process.pid
owned_pid = process.pid
record_diagnostic(f"child_pid={owned_pid}")

try:
    owned_session = os.getsid(pid)
    if owned_session != pid or owned_session == driver_session:
        raise RuntimeError(
            f"child session is not isolated: pid={pid} sid={owned_session} driver_sid={driver_session}"
        )
    remember_owned_pid(pid)
    foreground_group_owned = remember_foreground_group(terminal_fd)
    record_diagnostic(f"owned_session={owned_session}")
    record_diagnostic(f"child_group={os.getpgid(pid)}")
    record_diagnostic(f"foreground_group={os.tcgetpgrp(terminal_fd)}")
except (OSError, RuntimeError):
    try:
        os.kill(pid, signal.SIGKILL)
    except ProcessLookupError:
        pass
    process.wait()
    os.close(terminal_fd)
    raise
finally:
    signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)
attributes = termios.tcgetattr(terminal_fd)
attributes[3] &= ~termios.ECHO
termios.tcsetattr(terminal_fd, termios.TCSANOW, attributes)
if scenario == "cancel":
    command = f"source {cancel_harness} {root} {cancel_result}; exit\n"
else:
    command = (
        f"source {root}/lib/sley/sley.sh; "
        "sley_ready --exclude status --exclude check --exclude secrets --exclude verify; "
        "printf '__READY_RC__=%s\\n' \"$?\"; exit\n"
    )
os.write(terminal_fd, command.encode())

waiting_name = "formatter.started" if scenario == "cancel" else "interactive.waiting"
waiting_path = os.path.join(sync_dir, waiting_name)
output = bytearray()
deadline = time.monotonic() + 5
while (
    time.monotonic() < deadline
    and not os.path.exists(waiting_path)
    and process.poll() is None
):
    readable, _, _ = select.select([terminal_fd], [], [], 0.02)
    if readable:
        try:
            chunk = os.read(terminal_fd, 4096)
            if chunk:
                output.extend(chunk)
        except OSError:
            pass
started = os.path.exists(waiting_path)
if started:
    foreground_group_owned = remember_foreground_group(terminal_fd) or foreground_group_owned
    if scenario == "cancel":
        formatter_pid_path = os.path.join(sync_dir, "formatter.pid")
        with open(formatter_pid_path, encoding="ascii") as formatter_pid_file:
            remember_owned_pid(int(formatter_pid_file.read().strip()))
    os.write(terminal_fd, b"\x03" if scenario == "cancel" else b"input from terminal\n")

completed = False
deadline = time.monotonic() + 15
while time.monotonic() < deadline:
    readable, _, _ = select.select([terminal_fd], [], [], 0.05)
    if readable:
        try:
            output.extend(os.read(terminal_fd, 4096))
        except OSError:
            pass
    if process.poll() is not None:
        completed = True
        break

if not completed:
    record_diagnostic(f"timeout_poll={process.poll()}")
    record_diagnostic(f"terminal_output={output.decode(errors='replace')[-2000:]!r}")
    kill_owned_processes()
    process.wait()
else:
    kill_owned_processes()
try:
    while True:
        chunk = os.read(terminal_fd, 4096)
        if not chunk:
            break
