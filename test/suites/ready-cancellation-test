if started and mode == "format-long":
    with open(os.path.join(sync_dir, "formatter.pid"), encoding="ascii") as pid_file:
        formatter_pids.append(int(pid_file.read().strip()))
        remember_owned_pid(formatter_pids[-1])
if started:
    if mode == "identity-lost":
        open(env["SLEY_READY_TEST_IDENTITY_LOST_FILE"], "a", encoding="ascii").close()
    cancel_started = time.monotonic()
    os.kill(process.pid, getattr(signal, f"SIG{signal_name}"))
else:
    cancel_started = None
if started and mode == "format-delayed":
    formatter_started_path = os.path.join(sync_dir, "formatter.started")
    wait_for(lambda: os.path.exists(formatter_started_path) or process.poll() is not None, 1)
    late_formatter_started = os.path.exists(formatter_started_path)
    if late_formatter_started:
        with open(os.path.join(sync_dir, "formatter.pid"), encoding="ascii") as pid_file:
            formatter_pids.append(int(pid_file.read().strip()))
            remember_owned_pid(formatter_pids[-1])

completed = True
try:
    process.wait(timeout=15)
except subprocess.TimeoutExpired:
    completed = False
cancel_elapsed_ms = (
    int((time.monotonic() - cancel_started) * 1000) if cancel_started is not None else -1
)


def pid_exists(pid):
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def pid_running(pid):
    try:
        if os.path.exists(f"/proc/{pid}/stat"):
            with open(f"/proc/{pid}/stat", encoding="ascii") as stat_file:
                state = stat_file.read().rsplit(") ", 1)[1].split()[0]
        else:
            state = subprocess.check_output(
                ["ps", "-o", "stat=", "-p", str(pid)],
                text=True,
                stderr=subprocess.DEVNULL,
            ).strip()
        if state.startswith(("Z", "X")):
            return False
    except (FileNotFoundError, IndexError, OSError, subprocess.SubprocessError):
        pass
    return pid_exists(pid)


children_gone = wait_for(lambda: all(not pid_exists(pid) for pid in pids), 2)
descendants_gone = wait_for(lambda: all(not pid_running(pid) for pid in descendant_pids), 2)
formatters_gone = wait_for(lambda: all(not pid_running(pid) for pid in formatter_pids), 2)
term_cleanup_done = all(
    os.path.exists(os.path.join(sync_dir, f"{name}.term-cleanup")) for name in phase_names
