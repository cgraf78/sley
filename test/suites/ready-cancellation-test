import atexit
import glob
import os
import signal
import subprocess
import sys
import time

(
    bash,
    harness,
    root,
    repo,
    home,
    config,
    cache,
    tmpdir,
    sync_dir,
    mode,
    signal_name,
    output,
    result,
    trap_log,
) = sys.argv[1:]

env = os.environ.copy()
env.update(
    {
        "HOME": home,
        "XDG_CONFIG_HOME": config,
        "XDG_CACHE_HOME": cache,
        "GIT_CONFIG_GLOBAL": os.path.join(repo, ".gitconfig-test"),
        "SLEY_READY_TEST_MODE": (
            "format-long"
            if mode == "format-group-unavailable"
            else (
                "long"
                if mode in ("identity-unavailable", "identity-lost", "group-unavailable")
                else mode
            )
        ),
        "SLEY_READY_TEST_NO_IDENTITY": "1" if mode == "identity-unavailable" else "0",
        "SLEY_READY_TEST_NO_GROUP": (
            "1" if mode in ("group-unavailable", "format-group-unavailable") else "0"
        ),
        "SLEY_READY_TEST_IDENTITY_LOST_FILE": (
            os.path.join(sync_dir, "identity-lost") if mode == "identity-lost" else ""
        ),
        "SLEY_READY_TEST_NO_PS": (
            "1" if os.path.isdir("/proc") and mode == "format-long" else "0"
        ),
        "SLEY_READY_SYNC": sync_dir,
        "SLEY_READY_FORMATTER": os.environ["SLEY_READY_FORMATTER"],
        "SLEY_READY_TRAP_LOG": trap_log,
        "TMPDIR": tmpdir,
    }
)

process = None
owned_session = None
owned_pids = set()
owned_groups = set()
driver_session = os.getsid(0)


def remember_owned_pid(pid):
    if owned_session is None or pid == os.getpid():
        return False
    try:
        if os.getsid(pid) != owned_session:
            return False
        owned_pids.add(pid)
        owned_groups.add(os.getpgid(pid))
        return True
    except OSError:
        return False


def discover_owned_processes():
    if os.path.isdir("/proc"):
        try:
            entries = os.scandir("/proc")
        except OSError:
            return
        with entries:
            for entry in entries:
                if entry.name.isdigit():
                    remember_owned_pid(int(entry.name))
        return
    ps_command = os.environ.get("SLEY_READY_SYSTEM_PS")
    if not ps_command:
        return
    try:
        pid_output = subprocess.check_output(
            [ps_command, "-A", "-o", "pid="],
            text=True,
            stderr=subprocess.DEVNULL,
        )
    except (OSError, subprocess.SubprocessError):
        return
    for pid_text in pid_output.split():
        if pid_text.isdigit():
            remember_owned_pid(int(pid_text))


def kill_owned_processes():
    if owned_session is None or owned_session == driver_session:
        return
    for _ in range(3):
        discover_owned_processes()
        for pid in tuple(owned_pids):
            remember_owned_pid(pid)
        for process_group in tuple(owned_groups):
            try:
                os.killpg(process_group, signal.SIGKILL)
            except OSError:
                pass
        for pid in tuple(owned_pids):
            try:
                if os.getsid(pid) == owned_session:
                    os.kill(pid, signal.SIGKILL)
            except OSError:
                pass
        time.sleep(0.02)


def cleanup_owned_session():
    if owned_session is not None:
        kill_owned_processes()
    elif process is not None:
        try:
            os.killpg(process.pid, signal.SIGKILL)
        except OSError:
            pass


def interrupted(_signal_number, _frame):
    raise SystemExit(1)


atexit.register(cleanup_owned_session)
handled_signals = (signal.SIGINT, signal.SIGTERM, signal.SIGHUP)
for handled_signal in handled_signals:
    signal.signal(handled_signal, interrupted)

previous_mask = signal.pthread_sigmask(signal.SIG_BLOCK, handled_signals)
try:
    with open(output, "wb") as output_file:
        process = subprocess.Popen(
            [bash, "--noprofile", "--norc", harness, root, output, result],
            cwd=repo,
            env=env,
            stdout=output_file,
            stderr=subprocess.STDOUT,
            start_new_session=True,
            preexec_fn=lambda: signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask),
        )
    owned_session = os.getsid(process.pid)
    if owned_session != process.pid or owned_session == driver_session:
        raise RuntimeError(
            f"child session is not isolated: pid={process.pid} sid={owned_session} "
            f"driver_sid={driver_session}"
        )
    remember_owned_pid(process.pid)
finally:
    signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)


def wait_for(predicate, timeout):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(0.02)
    return predicate()


phase_names = ("phase-a", "phase-b")
pids = []
descendant_pids = []
formatter_pids = []
late_formatter_started = False
if mode == "format-long":
    started = wait_for(lambda: os.path.exists(os.path.join(sync_dir, "formatter.started")), 5)
elif mode == "format-delayed":
    started = wait_for(
        lambda: os.path.exists(os.path.join(sync_dir, "formatter.runner-waiting")), 5
    )
else:
    started = wait_for(
        lambda: all(os.path.exists(os.path.join(sync_dir, f"{name}.started")) for name in phase_names),
        5,
    )
if started and not mode.startswith("format-"):
    for name in phase_names:
        with open(os.path.join(sync_dir, f"{name}.pid"), encoding="ascii") as pid_file:
            pids.append(int(pid_file.read().strip()))
            remember_owned_pid(pids[-1])
        descendant_path = os.path.join(sync_dir, f"{name}.descendant.pid")
        if os.path.exists(descendant_path):
            with open(descendant_path, encoding="ascii") as pid_file:
