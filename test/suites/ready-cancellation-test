owned_session = None
owned_pids = set()
owned_groups = set()
driver_session = os.getsid(0)


def remember_owned_pid(pid):
    if owned_session is None or pid == os.getpid():
        return False
    try:
        if os.getsid(pid) != owned_session:
            return False
        owned_pids.add(pid)
        owned_groups.add(os.getpgid(pid))
