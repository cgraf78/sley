            stdout=output_file,
            stderr=subprocess.STDOUT,
            start_new_session=True,
            preexec_fn=lambda: signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask),
        )
    owned_session = os.getsid(process.pid)
    if owned_session != process.pid or owned_session == driver_session:
        raise RuntimeError(
            f"child session is not isolated: pid={process.pid} sid={owned_session} "
            f"driver_sid={driver_session}"
        )
    remember_owned_pid(process.pid)
finally:
    signal.pthread_sigmask(signal.SIG_SETMASK, previous_mask)


def wait_for(predicate, timeout):
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(0.02)
    return predicate()


phase_names = ("phase-a", "phase-b")
pids = []
descendant_pids = []
formatter_pids = []
if mode == "format-long":
