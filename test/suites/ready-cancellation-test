except subprocess.TimeoutExpired:
    completed = False


def pid_exists(pid):
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


children_gone = wait_for(lambda: all(not pid_exists(pid) for pid in pids), 2)
descendants_gone = wait_for(lambda: all(not pid_exists(pid) for pid in descendant_pids), 2)
formatters_gone = wait_for(lambda: all(not pid_exists(pid) for pid in formatter_pids), 2)
