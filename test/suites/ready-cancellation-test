    for name in phase_names:
        with open(os.path.join(sync_dir, f"{name}.pid"), encoding="ascii") as pid_file:
            pids.append(int(pid_file.read().strip()))
            remember_owned_pid(pids[-1])
        descendant_path = os.path.join(sync_dir, f"{name}.descendant.pid")
        if os.path.exists(descendant_path):
            with open(descendant_path, encoding="ascii") as pid_file:
                descendant_pids.append(int(pid_file.read().strip()))
                remember_owned_pid(descendant_pids[-1])
if started and mode == "format-long":
    with open(os.path.join(sync_dir, "formatter.pid"), encoding="ascii") as pid_file:
        formatter_pids.append(int(pid_file.read().strip()))
        remember_owned_pid(formatter_pids[-1])
if started:
    os.kill(process.pid, getattr(signal, f"SIG{signal_name}"))

completed = True
