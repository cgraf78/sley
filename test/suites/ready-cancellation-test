delayed_format_trap_log=$(_tmpdir)/delayed-format-TERM.traps
delayed_format_data=$(python3 "$signal_driver" \
  "$(command -v bash)" \
  "$harness" \
  "$SLEY_REPO_ROOT" \
  "$repo" \
  "$home" \
  "$config" \
  "$home/cache" \
  "$ready_tmp" \
  "$sync_dir" \
  format-delayed \
  TERM \
  "$delayed_format_output" \
  "$delayed_format_result" \
  "$delayed_format_trap_log")
_assert_eq "ready delayed formatter: hook runner starts before cancellation" \
  "yes" "$(_result_value started "$delayed_format_data")"
_assert_eq "ready delayed formatter: cleanup contains formatter fork during cancellation" \
  "no" "$(_result_value late_formatter_started "$delayed_format_data")"
_assert_eq "ready delayed formatter: sourced call returns within timeout" \
  "yes" "$(_result_value completed "$delayed_format_data")"
_assert_eq "ready delayed formatter: returns conventional signal status" \
  "143" "$(_result_value ready_rc "$delayed_format_data")"
_assert_eq "ready delayed formatter: late formatter is gone" \
  "yes" "$(_result_value formatters_gone "$delayed_format_data")"
_assert_eq "ready delayed formatter: cancelled hook runner does not resume hook code" \
  "no" "$([[ -e "$sync_dir/formatter.runner-resumed" ]] && printf yes || printf no)"

echo "=== sley: descendant cancellation cleanup ==="

for descendant_signal in INT TERM; do
  rm -f "$sync_dir"/* "$ready_tmp"/sley-ready-* 2>/dev/null || true
  descendant_output=$(_tmpdir)/"descendant-$descendant_signal.out"
  descendant_result=$(_tmpdir)/"descendant-$descendant_signal.result"
  descendant_trap_log=$(_tmpdir)/"descendant-$descendant_signal.traps"
  descendant_data=$(python3 "$signal_driver" \
    "$(command -v bash)" \
    "$harness" \
    "$SLEY_REPO_ROOT" \
    "$repo" \
    "$home" \
    "$config" \
    "$home/cache" \
    "$ready_tmp" \
    "$sync_dir" \
    descendant \
    "$descendant_signal" \
    "$descendant_output" \
    "$descendant_result" \
    "$descendant_trap_log")
  case "$descendant_signal" in
    INT) descendant_expected_rc=130 ;;
    TERM) descendant_expected_rc=143 ;;
  esac
  _assert_eq "ready descendant $descendant_signal: phases start" \
    "yes" "$(_result_value started "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: sourced call returns" \
    "yes" "$(_result_value completed "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: returns conventional signal status" \
    "$descendant_expected_rc" "$(_result_value ready_rc "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: phase children are gone" \
    "yes" "$(_result_value children_gone "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: phase descendants are gone" \
    "yes" "$(_result_value descendants_gone "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: leaves no temporary artifacts" \
    "0" "$(_result_value artifact_count "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: does not invoke caller trap" \
    "no" "$(_result_value caller_trap_fired "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: restores caller traps" \
    "yes" "$(_result_value traps_restored "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: preserves caller shell options" \
    "yes" "$(_result_value options_restored "$descendant_data")"
  _assert_eq "ready descendant $descendant_signal: leaks no cleanup globals" \
    "yes" "$(_result_value cleanup_globals_absent "$descendant_data")"
done

echo "=== sley: cooperative phase TERM cleanup ==="

rm -f "$sync_dir"/* "$ready_tmp"/sley-ready-* 2>/dev/null || true
term_cleanup_output=$(_tmpdir)/term-cleanup.out
term_cleanup_result=$(_tmpdir)/term-cleanup.result
term_cleanup_trap_log=$(_tmpdir)/term-cleanup.traps
term_cleanup_data=$(python3 "$signal_driver" \
  "$(command -v bash)" \
  "$harness" \
  "$SLEY_REPO_ROOT" \
  "$repo" \
  "$home" \
  "$config" \
  "$home/cache" \
  "$ready_tmp" \
  "$sync_dir" \
  term-cleanup \
  TERM \
  "$term_cleanup_output" \
  "$term_cleanup_result" \
  "$term_cleanup_trap_log")
_assert_eq "ready cooperative TERM: phases start" \
  "yes" "$(_result_value started "$term_cleanup_data")"
_assert_eq "ready cooperative TERM: sourced call returns" \
  "yes" "$(_result_value completed "$term_cleanup_data")"
_assert_eq "ready cooperative TERM: returns conventional signal status" \
  "143" "$(_result_value ready_rc "$term_cleanup_data")"
_assert_eq "ready cooperative TERM: phase cleanup handler completes" \
  "yes" "$(_result_value term_cleanup_done "$term_cleanup_data")"
term_cleanup_elapsed=$(_result_value cancel_elapsed_ms "$term_cleanup_data")
_assert_eq "ready cooperative TERM: cancellation completes within three seconds (${term_cleanup_elapsed}ms)" \
  "yes" "$(_millis_below "$term_cleanup_elapsed" 3000)"
_assert_eq "ready cooperative TERM: leaves no temporary artifacts" \
  "0" "$(_result_value artifact_count "$term_cleanup_data")"

_test_summary
