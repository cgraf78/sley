trap_fired = os.path.exists(trap_log) and os.path.getsize(trap_log) > 0
result_text = ""
if os.path.exists(result):
    with open(result, encoding="utf-8") as result_file:
        result_text = result_file.read().strip()

# The harness owns a dedicated session, including monitor-mode process groups.
# Cleanup is also registered with atexit and signal handlers above, so errors
# and test interruption cannot leave a synthetic worker tree behind.
if process.poll() is None or any(
    pid_exists(pid) for pid in pids + descendant_pids + formatter_pids
):
